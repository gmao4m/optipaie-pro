<UserControl x:Class="OptiPaie.Admin.Views.UpdatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Button DockPanel.Dock="Right" Content="Actualiser" Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}" />
            <TextBlock Text="Mises à jour" Style="{StaticResource H1}" VerticalAlignment="Center" />
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="18" Margin="0,16,0,0">
            <StackPanel>
                <TextBlock Text="Publier une version" Style="{StaticResource H2}" />
                <UniformGrid Columns="3" Margin="0,12,0,0">
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="Version" Style="{StaticResource Caption}" /><TextBox Style="{StaticResource AppTextBox}" Text="{Binding Version}" /></StackPanel>
                    <StackPanel Margin="8,0,8,0"><TextBlock Text="Canal" Style="{StaticResource Caption}" /><ComboBox Height="36" VerticalContentAlignment="Center" ItemsSource="{Binding Channels}" SelectedItem="{Binding Channel}" /></StackPanel>
                    <StackPanel Margin="8,0,0,0" VerticalAlignment="Bottom"><CheckBox Content="Mise à jour obligatoire" IsChecked="{Binding Mandatory}" Margin="0,0,0,8" /></StackPanel>
                </UniformGrid>
                <TextBlock Text="URL du package (release GitHub ou feed)" Style="{StaticResource Caption}" Margin="0,8,0,4" />
                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding PackageUrl}" />
                <TextBlock Text="Notes de version" Style="{StaticResource Caption}" Margin="0,8,0,4" />
                <TextBox Text="{Binding ReleaseNotes}" AcceptsReturn="True" Height="60" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         Background="White" BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" Padding="8" />
                <Button Content="Publier" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,12,0,0" Command="{Binding PublishCommand}" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,14,0,0">
            <DataGrid ItemsSource="{Binding Items}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Version" Binding="{Binding Version}" Width="120" FontFamily="Consolas" />
                    <DataGridTextColumn Header="Canal" Binding="{Binding Channel}" Width="90" />
                    <DataGridTextColumn Header="Type" Binding="{Binding MandatoryDisplay}" Width="120" />
                    <DataGridTextColumn Header="" Binding="{Binding LatestDisplay}" Width="90" />
                    <DataGridTextColumn Header="Publiée" Binding="{Binding PublishedDisplay}" Width="*" />
                    <DataGridTemplateColumn Header="" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Définir latest" Style="{StaticResource SecondaryButton}" Height="26" Padding="8,0" Margin="4,0"
                                            Command="{Binding DataContext.SetLatestCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                    <Button Content="Suppr." Style="{StaticResource SecondaryButton}" Height="26" Padding="8,0" Margin="4,0" Foreground="{StaticResource Bad}"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
