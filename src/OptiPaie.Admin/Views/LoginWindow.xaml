<Window x:Class="OptiPaie.Admin.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OptiPaie PRO — Administration"
        Height="470" Width="400" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" Background="{StaticResource Canvas}">
    <Grid>
        <Border Style="{StaticResource Card}" Width="330" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="30">
            <StackPanel>
                <Border Width="52" Height="52" CornerRadius="14" Background="{StaticResource Brand}" HorizontalAlignment="Left">
                    <TextBlock Text="OP" Foreground="White" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="OptiPaie PRO" Style="{StaticResource H1}" Margin="0,16,0,0" />
                <TextBlock Text="Console d'administration des licences" Style="{StaticResource Caption}" Margin="0,2,0,20" />

                <TextBlock Text="Email" Style="{StaticResource Caption}" Margin="0,0,0,4" />
                <TextBox x:Name="EmailBox" Style="{StaticResource AppTextBox}" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding NotBusy}" />

                <TextBlock Text="Mot de passe" Style="{StaticResource Caption}" Margin="0,12,0,4" />
                <PasswordBox x:Name="PasswordBox" Height="36" Padding="10,0" VerticalContentAlignment="Center"
                             Background="White" BorderBrush="{StaticResource BorderStrong}" BorderThickness="1"
                             IsEnabled="{Binding NotBusy}" KeyDown="Password_KeyDown" />

                <Button x:Name="LoginButton" Content="Se connecter" Style="{StaticResource PrimaryButton}" Height="40"
                        Margin="0,20,0,0" Click="Login_Click" IsEnabled="{Binding NotBusy}" />

                <TextBlock Text="{Binding Error}" Foreground="{StaticResource Bad}" FontSize="12.5" TextWrapping="Wrap" Margin="0,12,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
