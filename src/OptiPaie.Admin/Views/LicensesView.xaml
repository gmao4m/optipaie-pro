<UserControl x:Class="OptiPaie.Admin.Views.LicensesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Génération en lot" Style="{StaticResource SecondaryButton}" Command="{Binding BulkCommand}" Margin="0,0,8,0" />
                <Button Content="+ Nouvelle licence" Style="{StaticResource PrimaryButton}" Command="{Binding NewCommand}" />
            </StackPanel>
            <TextBlock Text="Licences" Style="{StaticResource H1}" VerticalAlignment="Center" />
        </DockPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,12">
            <TextBox Width="280" Style="{StaticResource AppTextBox}" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}"
                     ToolTip="Rechercher (clé, société, email)">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding RefreshCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <ComboBox Width="150" Height="36" Margin="8,0,0,0" ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding StatusFilter}" VerticalContentAlignment="Center" />
            <ComboBox Width="150" Height="36" Margin="8,0,0,0" ItemsSource="{Binding TypeFilters}" SelectedItem="{Binding TypeFilter}" VerticalContentAlignment="Center" />
            <Button Content="Rechercher" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Command="{Binding RefreshCommand}" />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Clé" Binding="{Binding LicenseKey}" Width="180" FontFamily="Consolas" />
                    <DataGridTextColumn Header="Client" Binding="{Binding CompanyName}" Width="*" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="110" />
                    <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="110" />
                    <DataGridTextColumn Header="Expiration" Binding="{Binding ExpiresDisplay}" Width="120" />
                    <DataGridTextColumn Header="Créée" Binding="{Binding CreatedDisplay}" Width="110" />
                    <DataGridTemplateColumn Header="" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Gérer" Style="{StaticResource SecondaryButton}" Height="28" Padding="10,0" Margin="4,0"
                                        Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="‹ Préc." Style="{StaticResource SecondaryButton}" Height="30" Command="{Binding PrevCommand}" Margin="0,0,8,0" />
                <Button Content="Suiv. ›" Style="{StaticResource SecondaryButton}" Height="30" Command="{Binding NextCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding PageInfo}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</UserControl>
