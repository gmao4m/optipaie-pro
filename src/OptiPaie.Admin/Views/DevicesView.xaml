<UserControl x:Class="OptiPaie.Admin.Views.DevicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <DockPanel Grid.Row="0">
            <Button DockPanel.Dock="Right" Content="Actualiser" Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}" />
            <TextBlock Text="Appareils" Style="{StaticResource H1}" VerticalAlignment="Center" />
        </DockPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,16,0,0">
            <DataGrid ItemsSource="{Binding Items}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" Width="220" FontFamily="Consolas" />
                    <DataGridTextColumn Header="Licence" Binding="{Binding LicenseKey}" Width="180" FontFamily="Consolas" />
                    <DataGridTextColumn Header="App" Binding="{Binding AppVersion}" Width="90" />
                    <DataGridTextColumn Header="Activé" Binding="{Binding ActivatedDisplay}" Width="110" />
                    <DataGridTextColumn Header="Dernière sync" Binding="{Binding LastSeenDisplay}" Width="150" />
                    <DataGridTextColumn Header="Statut" Binding="{Binding StatusDisplay}" Width="90" />
                    <DataGridTemplateColumn Header="" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Réinitialiser" Style="{StaticResource SecondaryButton}" Height="28" Padding="8,0" Margin="4,0" Foreground="{StaticResource Bad}"
                                        Command="{Binding DataContext.ResetCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
