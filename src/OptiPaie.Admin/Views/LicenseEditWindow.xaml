<Window x:Class="OptiPaie.Admin.Views.LicenseEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Licence" Height="720" Width="640" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" FontFamily="Segoe UI" Background="{StaticResource Canvas}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="20,16">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕" Style="{StaticResource SecondaryButton}" Width="36" Click="Close_Click" />
                <TextBlock Text="{Binding Title}" Style="{StaticResource H2}" VerticalAlignment="Center" FontFamily="Consolas" />
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="22">
                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,10"><TextBlock Text="Client / société" Style="{StaticResource Caption}" /><TextBox Style="{StaticResource AppTextBox}" Text="{Binding CompanyName}" /></StackPanel>
                    <StackPanel Margin="8,0,0,10"><TextBlock Text="Email" Style="{StaticResource Caption}" /><TextBox Style="{StaticResource AppTextBox}" Text="{Binding Email}" /></StackPanel>
                </UniformGrid>
                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,10"><TextBlock Text="Type" Style="{StaticResource Caption}" /><ComboBox Height="36" VerticalContentAlignment="Center" ItemsSource="{Binding Types}" SelectedItem="{Binding Type}" /></StackPanel>
                    <StackPanel Margin="8,0,0,10"><TextBlock Text="Appareils max" Style="{StaticResource Caption}" /><TextBox Style="{StaticResource AppTextBox}" Text="{Binding MaxDevices}" /></StackPanel>
                </UniformGrid>
                <UniformGrid Columns="2">
                    <StackPanel Margin="0,0,8,10"><TextBlock Text="Statut" Style="{StaticResource Caption}" /><ComboBox Height="36" VerticalContentAlignment="Center" ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}" /></StackPanel>
                    <StackPanel Margin="8,0,0,10"><TextBlock Text="Expiration (vide = permanente)" Style="{StaticResource Caption}" /><DatePicker Height="36" SelectedDate="{Binding Expires}" /></StackPanel>
                </UniformGrid>

                <WrapPanel Margin="0,6,0,0">
                    <Button Content="Enregistrer" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" Margin="0,0,8,8" />
                    <Button Content="Activer" Style="{StaticResource SecondaryButton}" Command="{Binding EnableCommand}" Margin="0,0,8,8" Visibility="{Binding IsExisting, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Désactiver" Style="{StaticResource SecondaryButton}" Command="{Binding DisableCommand}" Margin="0,0,8,8" Visibility="{Binding IsExisting, Converter={StaticResource BoolToVis}}" />
                    <Button Content="+30 jours" Style="{StaticResource SecondaryButton}" Command="{Binding ExtendCommand}" Margin="0,0,8,8" Visibility="{Binding IsExisting, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Réinit. appareils" Style="{StaticResource SecondaryButton}" Command="{Binding ResetDevicesCommand}" Margin="0,0,8,8" Visibility="{Binding IsExisting, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Supprimer" Style="{StaticResource SecondaryButton}" Command="{Binding DeleteCommand}" Foreground="{StaticResource Bad}" Margin="0,0,8,8" Visibility="{Binding IsExisting, Converter={StaticResource BoolToVis}}" />
                </WrapPanel>

                <StackPanel Visibility="{Binding IsExisting, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Modules" Style="{StaticResource H2}" Margin="0,16,0,8" />
                    <ItemsControl ItemsSource="{Binding ModuleList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,5">
                                    <TextBlock DockPanel.Dock="Right" Text="{Binding Info}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
                                    <CheckBox IsChecked="{Binding Enabled}" IsEnabled="{Binding CanToggle}" Content="{Binding Name}" VerticalContentAlignment="Center" />
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Clés d'activation de module" Style="{StaticResource H2}" Margin="0,18,0,8" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox Width="200" Height="34" VerticalContentAlignment="Center" ItemsSource="{Binding UpsellModules}" DisplayMemberPath="Name" SelectedValuePath="Key" SelectedValue="{Binding SelectedModule}" />
                        <DatePicker Width="150" Height="34" Margin="8,0,0,0" SelectedDate="{Binding KeyExpiry}" />
                        <Button Content="Générer une clé" Style="{StaticResource PrimaryButton}" Command="{Binding GenerateKeyCommand}" Margin="8,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="{Binding NewKeyInfo}" FontFamily="Consolas" Foreground="{StaticResource Brand}" Margin="0,0,0,8" />
                    <Border Style="{StaticResource Card}" Padding="0" Height="200">
                        <DataGrid ItemsSource="{Binding Keys}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Module" Binding="{Binding ModuleKey}" Width="120" />
                                <DataGridTextColumn Header="Clé" Binding="{Binding KeyCode}" Width="*" FontFamily="Consolas" />
                                <DataGridTextColumn Header="Statut" Binding="{Binding Status}" Width="90" />
                                <DataGridTextColumn Header="Créée" Binding="{Binding CreatedDisplay}" Width="100" />
                                <DataGridTemplateColumn Header="" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Révoquer" Style="{StaticResource SecondaryButton}" Height="26" Padding="8,0" Margin="4,0" Foreground="{StaticResource Bad}"
                                                    Command="{Binding DataContext.RevokeKeyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
