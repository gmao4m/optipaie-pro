<UserControl x:Class="OptiPaie.Admin.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Rapports" Style="{StaticResource H1}" />
        <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="*" /></Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,8,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Activation des modules" Style="{StaticResource H2}" Margin="16,14" />
                    <DataGrid ItemsSource="{Binding ModuleStats}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Module" Binding="{Binding NameFr}" Width="*" />
                            <DataGridTextColumn Header="Licences" Binding="{Binding EnabledCount}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,8">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Licences par type" Style="{StaticResource H2}" Margin="16,14" />
                    <DataGrid ItemsSource="{Binding TypeStats}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding Key}" Width="*" />
                            <DataGridTextColumn Header="Total" Binding="{Binding Value}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource Card}" Margin="0,8,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Licences par statut" Style="{StaticResource H2}" Margin="16,14" />
                    <DataGrid ItemsSource="{Binding StatusStats}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Statut" Binding="{Binding Key}" Width="*" />
                            <DataGridTextColumn Header="Total" Binding="{Binding Value}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Margin="8,8,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Clés d'activation de module" Style="{StaticResource H2}" Margin="16,14" />
                    <DataGrid ItemsSource="{Binding KeyStats}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Statut" Binding="{Binding Key}" Width="*" />
                            <DataGridTextColumn Header="Total" Binding="{Binding Value}" Width="120" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
