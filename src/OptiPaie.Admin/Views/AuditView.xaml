<UserControl x:Class="OptiPaie.Admin.Views.AuditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Journal d'audit" Style="{StaticResource H1}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,16,0,12">
            <ComboBox Width="240" Height="36" VerticalContentAlignment="Center" ItemsSource="{Binding Actions}" SelectedItem="{Binding ActionFilter}" />
            <Button Content="Actualiser" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Command="{Binding RefreshCommand}" />
        </StackPanel>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <DataGrid ItemsSource="{Binding Items}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date" Binding="{Binding CreatedDisplay}" Width="150" />
                    <DataGridTextColumn Header="Administrateur" Binding="{Binding Actor}" Width="200" />
                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="200" />
                    <DataGridTextColumn Header="Client" Binding="{Binding CompanyName}" Width="*" />
                    <DataGridTextColumn Header="Clé" Binding="{Binding LicenseKey}" Width="180" FontFamily="Consolas" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="‹ Préc." Style="{StaticResource SecondaryButton}" Height="30" Command="{Binding PrevCommand}" Margin="0,0,8,0" />
                <Button Content="Suiv. ›" Style="{StaticResource SecondaryButton}" Height="30" Command="{Binding NextCommand}" />
            </StackPanel>
            <TextBlock Text="{Binding PageInfo}" Style="{StaticResource Caption}" VerticalAlignment="Center" />
        </DockPanel>
    </Grid>
</UserControl>
