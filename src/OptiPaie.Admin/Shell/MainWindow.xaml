<Window x:Class="OptiPaie.Admin.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptiPaie.Admin.ViewModels"
        xmlns:views="clr-namespace:OptiPaie.Admin.Views"
        Title="OptiPaie PRO — Administration" Height="820" Width="1240"
        MinWidth="1040" MinHeight="640" WindowStartupLocation="CenterScreen" WindowState="Maximized"
        FontFamily="Segoe UI" Background="{StaticResource Canvas}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}"><views:DashboardView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:LicensesViewModel}"><views:LicensesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DevicesViewModel}"><views:DevicesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:UpdatesViewModel}"><views:UpdatesView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}"><views:ReportsView /></DataTemplate>
        <DataTemplate DataType="{x:Type vm:AuditViewModel}"><views:AuditView /></DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,16">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,0,0,18">
                    <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource Brand}">
                        <TextBlock Text="OP" Foreground="White" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="Admin" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="15.5" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="1" Background="{StaticResource Border}" Margin="4,10" />
                    <TextBlock Text="{Binding UserEmail}" Style="{StaticResource Caption}" Margin="12,0,0,4" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel>
                    <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="📊  Tableau de bord" IsChecked="True" Command="{Binding NavigateCommand}" CommandParameter="dashboard" />
                    <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="🔑  Licences" Command="{Binding NavigateCommand}" CommandParameter="licenses" />
                    <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="💻  Appareils" Command="{Binding NavigateCommand}" CommandParameter="devices" />
                    <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="⬆️  Mises à jour" Command="{Binding NavigateCommand}" CommandParameter="updates" />
                    <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="📈  Rapports" Command="{Binding NavigateCommand}" CommandParameter="reports" />
                    <RadioButton Style="{StaticResource NavItem}" GroupName="nav" Content="📜  Journal d'audit" Command="{Binding NavigateCommand}" CommandParameter="audit" />
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1" Content="{Binding Current}" />
    </Grid>
</Window>
