<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <runtime>
    <!-- GC tuned for a desktop UI on low-spec machines. -->
    <gcServer enabled="false" />
    <gcConcurrent enabled="true" />
  </runtime>

  <appSettings>
    <!--
      Machine-level bootstrap settings only (everything else lives in the SQLite
      database). These are read before the database is opened.
      Leaving DataDirectory empty makes the app use %AppData%\OptiPaie DZ.
    -->
    <add key="DataDirectory" value="" />
    <add key="DefaultLanguage" value="fr" />
  </appSettings>

  <!--
    High-DPI rendering (the other half of app.manifest's PerMonitorV2 declaration).
    On .NET Framework 4.7+ the manifest only marks the process DPI-aware to the OS;
    WinForms (and therefore the DevExpress controls) only render NATIVELY at the
    monitor's DPI when this section opts in. Without it the UI is drawn at 96 DPI and
    composited against a DPI-aware surface, which is what causes blurry text and the
    white ClearType halos at 125–200 %. PerMonitorV2 + auto-resizing fixes that at the
    source for every label, grid, button and caption; Windows 7/8 fall back to the
    System awareness already declared in the manifest.
  -->
  <System.Windows.Forms.ApplicationConfigurationSection>
    <add key="DpiAwareness" value="PerMonitorV2" />
    <add key="EnableWindowsFormsHighDpiAutoResizing" value="true" />
  </System.Windows.Forms.ApplicationConfigurationSection>

</configuration>
