<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>

  <appSettings>
    <!-- Data directory / language default to %AppData%\OptiPaie DZ and French when blank. -->
    <add key="DataDirectory" value="" />
    <add key="DefaultLanguage" value="fr" />

    <!--
      ===== CONNECT TO YOUR SUPABASE PROJECT: fill the TWO values below =====
      (Both are PUBLIC and safe to embed. See backend/CONNECT.md.)

        Licensing.BaseUrl : your Edge Functions base URL, i.e.
                            https://<PROJECT-REF>.functions.supabase.co
                            (<PROJECT-REF> is the sub-domain of your Project URL)
        Licensing.AnonKey : Project Settings -> API -> Project API keys -> "anon public"

      The Ed25519 PUBLIC key is already embedded in code (LicensingConfig.cs).
      Leave these blank to keep the app offline-only (trial). Fill them to enable
      online activation. The two explicit *Url keys are optional overrides.
    -->
    <add key="Licensing.BaseUrl" value="https://bajiomgtkpdqyvgpigsc.supabase.co/functions/v1" />
    <add key="Licensing.ActivateUrl" value="" />
    <add key="Licensing.ValidateUrl" value="" />
    <add key="Licensing.AnonKey" value="sb_publishable_AAbnVY311vyP8hfD5WcEUg_0RDiYqxb" />

    <!--
      Auto-update source. Preferred: GitHub Releases — set Update.GitHubRepo to
      "owner/repo" (public repo). The client reads the latest release, compares the
      tag to the running version, and offers to download the Setup.exe asset.
        e.g. Update.GitHubRepo = chihab/optipaie-pro
      Alternatively use a Velopack feed URL (Update.FeedUrl), e.g. a public Supabase
      Storage bucket. Leave BOTH blank to disable updates (the app still runs).
      The mandatory flag comes from the Supabase `updates` table (Admin Panel);
      release notes come from the GitHub release body.
    -->
    <add key="Update.GitHubRepo" value="gmao4m/optipaie-pro" />
    <add key="Update.FeedUrl" value="" />

    <!--
      Support contact shown when the 48-hour trial ends (and in the activation window).
      Fill these with your real commercial contact before distributing.
    -->
    <add key="Support.Phone" value="+213 000 00 00 00" />
    <add key="Support.Email" value="contact@optipaie.dz" />
  </appSettings>
</configuration>
