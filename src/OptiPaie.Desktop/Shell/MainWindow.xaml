<Window x:Class="OptiPaie.Desktop.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptiPaie.Desktop.ViewModels"
        xmlns:views="clr-namespace:OptiPaie.Desktop.Views"
        Title="OptiPaie PRO" Height="820" Width="1280"
        MinWidth="1120" MinHeight="720"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        FontFamily="Segoe UI" Background="{StaticResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Window.Resources>
        <!-- Page templates -->
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeesViewModel}">
            <views:EmployeesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CompaniesViewModel}">
            <views:CompaniesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayrollViewModel}">
            <views:PayrollView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArchiveViewModel}">
            <views:ArchiveView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AttendanceViewModel}">
            <views:AttendanceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LeaveViewModel}">
            <views:LeaveView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoanViewModel}">
            <views:LoanView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContractViewModel}">
            <views:ContractView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PerformanceViewModel}">
            <views:PerformanceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AssetViewModel}">
            <views:AssetView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PremiumModuleViewModel}">
            <views:PremiumModuleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModuleReadyViewModel}">
            <views:PlaceholderView />
        </DataTemplate>

        <!-- One navigation entry (bound to a NavItemViewModel) -->
        <DataTemplate x:Key="NavItemTemplate" DataType="{x:Type vm:NavItemViewModel}">
            <Button Command="{Binding Command}" Cursor="Hand" Height="42" Margin="0,1"
                    HorizontalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="12,0">
                            <DockPanel>
                                <Path x:Name="ic" DockPanel.Dock="Left" Width="19" Height="19" Stretch="Uniform"
                                      Fill="{StaticResource TextSecondary}" Data="{Binding Icon}" VerticalAlignment="Center" />
                                <Path x:Name="lk" DockPanel.Dock="Right" Width="14" Height="14" Stretch="Uniform"
                                      Fill="{StaticResource TextMuted}" Data="{StaticResource IconLock}" VerticalAlignment="Center"
                                      Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock x:Name="tx" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextSecondary}" Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceMuted}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource BrandSoft}" />
                                <Setter TargetName="ic" Property="Fill" Value="{StaticResource Brand}" />
                                <Setter TargetName="tx" Property="Foreground" Value="{StaticResource Brand}" />
                                <Setter TargetName="tx" Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="222" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Navigation rail -->
        <Border Grid.Column="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,16">
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,0,0,16">
                    <Border Width="30" Height="30" CornerRadius="8" Background="{StaticResource Brand}">
                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{StaticResource TextOnBrand}" Data="{StaticResource IconWallet}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="OptiPaie" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="15.5" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" />
                </StackPanel>

                <!-- Settings pinned to the bottom -->
                <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding SettingsNav}" ItemTemplate="{StaticResource NavItemTemplate}" />

                <!-- Scrollable main navigation (core + premium modules) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CoreNav}" ItemTemplate="{StaticResource NavItemTemplate}" />

                        <Border Height="1" Background="{StaticResource Border}" Margin="6,12" />
                        <TextBlock Text="MODULES PREMIUM" Margin="12,0,0,8" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextMuted}" />

                        <ItemsControl ItemsSource="{Binding ModuleNav}" ItemTemplate="{StaticResource NavItemTemplate}" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content -->
        <ContentControl Grid.Column="1" Content="{Binding Current}" />
    </Grid>
</Window>
