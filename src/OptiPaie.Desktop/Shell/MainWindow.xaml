<Window x:Class="OptiPaie.Desktop.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:OptiPaie.Desktop.ViewModels"
        xmlns:vma="clr-namespace:OptiPaie.Desktop.ViewModels.Attendance"
        xmlns:views="clr-namespace:OptiPaie.Desktop.Views"
        Title="OptiPaie PRO" Height="820" Width="1280"
        MinWidth="1120" MinHeight="720"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        FontFamily="Segoe UI" Background="{DynamicResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Window.Resources>
        <!-- Page templates -->
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
            <views:ReportsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HomeViewModel}">
            <views:HomeView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EmployeesViewModel}">
            <views:EmployeesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CompaniesViewModel}">
            <views:CompaniesView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PayrollViewModel}">
            <views:PayrollView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ArchiveViewModel}">
            <views:ArchiveView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vma:AttendanceMatrixViewModel}">
            <views:AttendanceMatrixView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LeaveViewModel}">
            <views:LeaveView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoanViewModel}">
            <views:LoanView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ContractViewModel}">
            <views:ContractView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PerformanceViewModel}">
            <views:PerformanceView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AssetViewModel}">
            <views:AssetView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrainingViewModel}">
            <views:TrainingView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AtsViewModel}">
            <views:AtsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CertificateViewModel}">
            <views:CertificateView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PremiumModuleViewModel}">
            <views:PremiumModuleView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ModuleReadyViewModel}">
            <views:PlaceholderView />
        </DataTemplate>

        <!-- One navigation entry (bound to a NavItemViewModel) -->
        <DataTemplate x:Key="NavItemTemplate" DataType="{x:Type vm:NavItemViewModel}">
            <Button Command="{Binding Command}" Cursor="Hand" Height="42" Margin="0,1"
                    HorizontalContentAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="12,0">
                            <DockPanel>
                                <Path x:Name="ic" DockPanel.Dock="Left" Width="19" Height="19" Stretch="Uniform"
                                      Fill="{DynamicResource TextSecondary}" Data="{Binding Icon}" VerticalAlignment="Center" />
                                <Path x:Name="lk" DockPanel.Dock="Right" Width="14" Height="14" Stretch="Uniform"
                                      Fill="{DynamicResource TextMuted}" Data="{StaticResource IconLock}" VerticalAlignment="Center"
                                      Visibility="{Binding IsLocked, Converter={StaticResource BoolToVis}}" />
                                <TextBlock x:Name="tx" Margin="12,0,0,0" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondary}" Text="{Binding Title}"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                            </Trigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BrandSoft}" />
                                <Setter TargetName="ic" Property="Fill" Value="{DynamicResource Brand}" />
                                <Setter TargetName="tx" Property="Foreground" Value="{DynamicResource Brand}" />
                                <Setter TargetName="tx" Property="FontWeight" Value="SemiBold" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="222" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Navigation rail -->
        <Border Grid.Column="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,1,0">
            <DockPanel Margin="12,16">
                <!-- Brand -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="6,0,0,16">
                    <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource Brand}">
                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}" Data="{StaticResource IconWallet}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="OptiPaie" VerticalAlignment="Center" Margin="10,0,0,0" FontSize="15.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                </StackPanel>

                <!-- Settings + sign-out pinned to the bottom -->
                <StackPanel DockPanel.Dock="Bottom">
                    <ItemsControl ItemsSource="{Binding SettingsNav}" ItemTemplate="{StaticResource NavItemTemplate}" />
                    <Border Height="1" Background="{DynamicResource Border}" Margin="6,6" />
                    <Button Command="{Binding SignOutCommand}" Cursor="Hand" Height="42" Margin="0,1" HorizontalContentAlignment="Stretch"
                            ToolTip="Se déconnecter et revenir à l'écran de démarrage">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="12,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Path Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource Deduction}" Data="{StaticResource IconLock}" VerticalAlignment="Center" />
                                        <TextBlock Text="Se déconnecter" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource Deduction}" FontSize="13.5" FontWeight="SemiBold" />
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Scrollable main navigation (core + premium modules) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding CoreNav}" ItemTemplate="{StaticResource NavItemTemplate}" />

                        <Border Height="1" Background="{DynamicResource Border}" Margin="6,12" />
                        <TextBlock Text="MODULES PREMIUM" Margin="12,0,0,8" FontSize="10.5" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMuted}" />

                        <ItemsControl ItemsSource="{Binding ModuleNav}" ItemTemplate="{StaticResource NavItemTemplate}" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- Content area with a top bar (notification bell) -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                <Grid>
                    <!-- Global company selector: the single, always-visible active-company
                         switch every module reads from. Shows the active company's logo + name. -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Path Width="15" Height="15" Stretch="Uniform" Fill="{DynamicResource TextMuted}"
                              Data="{StaticResource IconBuilding}" VerticalAlignment="Center" />
                        <TextBlock Text="Entreprise active" Margin="8,0,10,0" VerticalAlignment="Center"
                                   FontSize="11.5" Foreground="{DynamicResource TextMuted}" />
                        <ComboBox ItemsSource="{Binding CompanyContext.Companies}"
                                  SelectedItem="{Binding CompanyContext.Active, Mode=TwoWay}"
                                  MinWidth="230" Height="32" VerticalContentAlignment="Center"
                                  FontSize="13" FontWeight="SemiBold" ToolTip="Changer d'entreprise (s'applique à tous les modules)">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="5" Background="{DynamicResource BrandSoft}" VerticalAlignment="Center">
                                            <Grid>
                                                <Path Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource Brand}"
                                                      Data="{StaticResource IconBuilding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <Image Source="{Binding Logo, Converter={StaticResource BytesToImage}}" Width="22" Height="22" Stretch="UniformToFill" />
                                            </Grid>
                                        </Border>
                                        <TextBlock Text="{Binding NameFr}" Margin="9,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <Button Style="{StaticResource SecondaryButton}" Height="30" Padding="12,0" FontSize="12"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,140,0"
                            Command="{Binding ToggleThemeCommand}" Content="{Binding ThemeToggleText}"
                            ToolTip="Basculer entre le thème clair et le thème sombre" />

                    <ToggleButton x:Name="BellButton" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,18,0"
                                  Background="Transparent" BorderThickness="0" Cursor="Hand" Padding="10,6">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <StackPanel Orientation="Horizontal">
                                            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TextSecondary}"
                                                  Data="{StaticResource IconClock}" VerticalAlignment="Center" />
                                            <TextBlock Text="Alertes" Margin="7,0,0,0" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextSecondary}" FontSize="12.5" FontWeight="SemiBold" />
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-6,0"
                                                Background="{DynamicResource Deduction}" CornerRadius="9" MinWidth="18" Height="18" Padding="4,0"
                                                Visibility="{Binding HasNotifications, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="{Binding NotificationBadge}" Foreground="White" FontSize="10.5" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>

                    <Popup IsOpen="{Binding IsChecked, ElementName=BellButton}" StaysOpen="False" Placement="Bottom"
                           PlacementTarget="{Binding ElementName=BellButton}" HorizontalOffset="-300" AllowsTransparency="True"
                           PopupAnimation="Fade">
                        <Border Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1"
                                CornerRadius="10" Width="380" Margin="8" >
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="2" Opacity="0.18" Color="#000000" />
                            </Border.Effect>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Notifications" FontWeight="SemiBold" FontSize="14" Margin="14,12,14,6" />
                                <ScrollViewer Grid.Row="1" MaxHeight="420" VerticalScrollBarVisibility="Auto" Margin="6,0,6,8">
                                    <StackPanel>
                                        <ItemsControl ItemsSource="{Binding Notifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button HorizontalContentAlignment="Stretch" BorderThickness="0" Background="Transparent" Cursor="Hand"
                                                            Command="{Binding DataContext.OpenNotificationCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}">
                                                        <Border Background="{DynamicResource SurfaceMuted}" CornerRadius="8" Padding="10,8" Margin="0,2">
                                                            <StackPanel Orientation="Horizontal">
                                                                <Border Width="9" Height="9" CornerRadius="5" VerticalAlignment="Top" Margin="0,3,9,0"
                                                                        Background="{Binding Severity, Converter={StaticResource SeverityBrush}}" />
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12.5" TextWrapping="Wrap" />
                                                                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondary}" FontSize="11.5"
                                                                               Margin="0,2,0,0" TextWrapping="Wrap" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Border>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <TextBlock Text="Aucune notification — tout est à jour." Foreground="{DynamicResource TextMuted}"
                                                   HorizontalAlignment="Center" Margin="0,18"
                                                   Visibility="{Binding HasNotifications, Converter={StaticResource InverseBoolToVis}}" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Popup>
                </Grid>
            </Border>

            <ContentControl Grid.Row="1" Content="{Binding Current}" />
        </Grid>
    </Grid>
</Window>
