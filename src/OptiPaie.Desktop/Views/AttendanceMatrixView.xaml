<UserControl x:Class="OptiPaie.Desktop.Views.AttendanceMatrixView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Kpi" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,9" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <!-- Status brush button: highlights when selected -->
        <Style x:Key="BrushButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" CornerRadius="6" BorderBrush="{StaticResource BorderStrong}" BorderThickness="1"
                                Background="{Binding Fill}" Padding="10,6">
                            <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="SemiBold" Foreground="#1B2430" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource TextPrimary}" />
                                <Setter TargetName="b" Property="BorderThickness" Value="2.5" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title + filters -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="Matrice de présence" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0"
                           Text="Un seul écran pour tout le mois. Choisissez un statut, cliquez les cellules — enregistrement automatique." />
            </StackPanel>
        </Grid>

        <!-- Filter bar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,10" Margin="0,14,0,0">
            <WrapPanel Orientation="Horizontal">
                <ComboBox Style="{StaticResource AppComboBox}" Width="180" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}" DisplayMemberPath="NameFr" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="180" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="120" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding Months}" SelectedValue="{Binding SelectedMonth}"
                          SelectedValuePath="Value" DisplayMemberPath="Label" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="90" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="160" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding StatusFilters}" SelectedItem="{Binding SelectedStatusFilter}" DisplayMemberPath="Label" />
                <TextBox Style="{StaticResource AppTextBox}" Width="180" Height="32" Margin="0,0,8,0"
                         Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,8,0" Content="Mois courant" Command="{Binding TodayCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Content="Actualiser" Command="{Binding RefreshCommand}" />
            </WrapPanel>
        </Border>

        <!-- KPI strip -->
        <WrapPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Taux de présence" />
                    <TextBlock Style="{StaticResource KpiValue}" Foreground="{StaticResource Salary}" Text="{Binding KpiAttendance}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Taux d'absence" />
                    <TextBlock Style="{StaticResource KpiValue}" Foreground="{StaticResource Deduction}" Text="{Binding KpiAbsence}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Taux de retard" />
                    <TextBlock Style="{StaticResource KpiValue}" Foreground="{StaticResource Warning}" Text="{Binding KpiLate}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Jours ouvrés" />
                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding KpiWorkingDays}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Présents aujourd'hui" />
                    <TextBlock Style="{StaticResource KpiValue}" Foreground="{StaticResource Salary}" Text="{Binding KpiPresentToday}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="En congé" />
                    <TextBlock Style="{StaticResource KpiValue}" Foreground="{StaticResource Employer}" Text="{Binding KpiOnLeave}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="En mission" />
                    <TextBlock Style="{StaticResource KpiValue}" Foreground="{StaticResource Employer}" Text="{Binding KpiOnMission}" /></StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Effectif" />
                    <TextBlock Style="{StaticResource KpiValue}" Text="{Binding KpiEmployees}" /></StackPanel>
            </Border>
        </WrapPanel>

        <!-- Palette + bulk toolbar -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="12,10" Margin="0,12,0,0">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Statut :" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding Palette}" VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource BrushButton}"
                                    Command="{Binding DataContext.SelectBrushCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Border Width="1" Background="{StaticResource Border}" Margin="10,2" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,6,0"
                        Content="Appliquer au mois (sélection)" Command="{Binding ApplyMonthToSelectionCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,6,0" Content="Tout cocher" Command="{Binding SelectAllCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,6,0" Content="Décocher" Command="{Binding ClearSelectionCommand}" />
                <Border Width="1" Background="{StaticResource Border}" Margin="10,2" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="0,0,6,0" Content="Rapports du mois" Command="{Binding MonthSummaryCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Content="Paramètres" Command="{Binding SettingsCommand}" />
            </WrapPanel>
        </Border>

        <!-- Matrix -->
        <DataGrid x:Name="Grid" Grid.Row="4" Margin="0,12,0,0"
                  AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" CanUserDeleteRows="False"
                  CanUserReorderColumns="False" CanUserResizeRows="False" SelectionMode="Single" IsReadOnly="True"
                  EnableRowVirtualization="True" EnableColumnVirtualization="True"
                  VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                  VirtualizingPanel.ScrollUnit="Pixel" ColumnWidth="Auto"
                  RowHeight="28" FontFamily="Segoe UI" FontSize="12" Background="{StaticResource Surface}"
                  RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource SurfaceMuted}"
                  BorderBrush="{StaticResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{StaticResource Border}" VerticalGridLinesBrush="{StaticResource Border}"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.CanContentScroll="True" />

        <!-- Legend + status -->
        <Grid Grid.Row="5" Margin="0,10,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ItemsControl ItemsSource="{Binding Palette}">
                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                                <Border Width="14" Height="14" CornerRadius="3" Background="{Binding Fill}" BorderBrush="{StaticResource BorderStrong}" BorderThickness="1" />
                                <TextBlock Text="{Binding Label}" Margin="4,0,0,0" FontSize="11" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
