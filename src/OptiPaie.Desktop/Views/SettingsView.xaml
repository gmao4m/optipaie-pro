<UserControl x:Class="OptiPaie.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <!-- One label/value row on the License card -->
        <Style x:Key="LicLabel" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="LicValue" TargetType="TextBlock" BasedOn="{StaticResource Body}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Paramètres" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="Préférences de l'application, licence et sécurité des données" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,0,0">
            <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                <!-- General preferences -->
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Préférences générales" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Langue de l'application" />
                            <ComboBox Grid.Column="1" Width="240" HorizontalAlignment="Left" Style="{StaticResource AppComboBox}"
                                      ItemsSource="{Binding Languages}" SelectedValue="{Binding Language}" SelectedValuePath="Value" DisplayMemberPath="Label" />
                        </Grid>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Taux CNAS salarié" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding CnasRateText}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- License -->
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel>
                            <Border DockPanel.Dock="Right" Background="{StaticResource BrandSoft}" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AccessStateText}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Brand}" />
                            </Border>
                            <TextBlock Style="{StaticResource H2}" Text="Licence" VerticalAlignment="Center" />
                        </DockPanel>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Client" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding CustomerText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Type de licence" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding LicenseTypeText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Produit" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ProductText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Clé de licence" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource LicValue}" FontFamily="Consolas" Text="{Binding LicenseKeyText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Expiration" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ExpirationText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Activée le" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ActivatedText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Identifiant appareil" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource LicValue}" FontFamily="Consolas" Text="{Binding DeviceIdText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource LicLabel}" Text="Modules" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ModulesText}" />
                        </Grid>

                        <WrapPanel Margin="0,20,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Content="Renouveler / Activer" Command="{Binding RenewCommand}" Margin="0,0,10,10" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Activer un module" Command="{Binding ActivateModuleCommand}" Margin="0,0,10,10" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Désactiver l'appareil" Command="{Binding DeactivateCommand}" Margin="0,0,10,10" />
                            <Button Style="{StaticResource SecondaryButton}" Content="Vérifier les mises à jour" Command="{Binding CheckUpdatesCommand}" Margin="0,0,10,10" />
                        </WrapPanel>
                        <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0" Text="{Binding LastUpdateCheckText}" />
                    </StackPanel>
                </Border>

                <!-- Data & security -->
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="Données et sécurité" />
                        <TextBlock Style="{StaticResource Caption}" Margin="0,6,0,16" Text="Sauvegardez régulièrement votre base de données." />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" Content="Sauvegarder maintenant" Command="{Binding BackupCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Content="Restaurer une sauvegarde" Command="{Binding RestoreCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource Caption}" Text="{Binding VersionText}" Margin="0,0,0,10" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
