<UserControl x:Class="OptiPaie.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization">
    <UserControl.Resources>
        <!-- One label/value row on the License card -->
        <Style x:Key="LicLabel" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="LicValue" TargetType="TextBlock" BasedOn="{StaticResource Body}">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="{loc:Loc Shell_Nav_Settings}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{loc:Loc Settings_Subtitle}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,22,0,0">
            <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                <!-- General preferences -->
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="{loc:Loc Settings_GroupPreferences}" />
                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{loc:Loc Settings_AppLanguage}" />
                            <ComboBox Grid.Column="1" Width="240" HorizontalAlignment="Left" Style="{StaticResource AppComboBox}"
                                      ItemsSource="{Binding Languages}" SelectedValue="{Binding Language}" SelectedValuePath="Value" DisplayMemberPath="Label" />
                        </Grid>
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="{loc:Loc Settings_CnasRate}" />
                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="{Binding CnasRateText}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- License -->
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <DockPanel>
                            <Border DockPanel.Dock="Right" Background="{DynamicResource BrandSoft}" CornerRadius="6" Padding="10,4" VerticalAlignment="Center">
                                <TextBlock Text="{Binding AccessStateText}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource Brand}" />
                            </Border>
                            <TextBlock Style="{StaticResource H2}" Text="{loc:Loc Settings_License}" VerticalAlignment="Center" />
                        </DockPanel>

                        <Grid Margin="0,18,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_Customer}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding CustomerText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_LicenseType}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding LicenseTypeText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_Product}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ProductText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_LicenseKey}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource LicValue}" FontFamily="Consolas" Text="{Binding LicenseKeyText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_Expiration}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ExpirationText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_ActivatedOn}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ActivatedText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_DeviceId}" Margin="0,0,0,10" />
                            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource LicValue}" FontFamily="Consolas" Text="{Binding DeviceIdText}" Margin="0,0,0,10" />

                            <TextBlock Grid.Row="7" Grid.Column="0" Style="{StaticResource LicLabel}" Text="{loc:Loc Settings_Modules}" />
                            <TextBlock Grid.Row="7" Grid.Column="1" Style="{StaticResource LicValue}" Text="{Binding ModulesText}" />
                        </Grid>

                        <WrapPanel Margin="0,20,0,0">
                            <Button Style="{StaticResource PrimaryButton}" Content="{loc:Loc Settings_Renew}" Command="{Binding RenewCommand}" Margin="0,0,10,10" />
                            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Settings_ActivateModule}" Command="{Binding ActivateModuleCommand}" Margin="0,0,10,10" />
                            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Settings_Deactivate}" Command="{Binding DeactivateCommand}" Margin="0,0,10,10" />
                            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Settings_CheckUpdates}" Command="{Binding CheckUpdatesCommand}" Margin="0,0,10,10" />
                        </WrapPanel>
                        <TextBlock Style="{StaticResource Caption}" Margin="0,2,0,0" Text="{Binding LastUpdateCheckText}" />
                    </StackPanel>
                </Border>

                <!-- Data & security -->
                <Border Style="{StaticResource Card}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="{loc:Loc Settings_GroupSecurity}" />
                        <TextBlock Style="{StaticResource Caption}" Margin="0,6,0,16" Text="{loc:Loc Settings_BackupHint}" />
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource PrimaryButton}" Content="{loc:Loc Settings_BackupNow}" Command="{Binding BackupCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Content="{loc:Loc Settings_RestoreBackup}" Command="{Binding RestoreCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Style="{StaticResource Caption}" Text="{Binding VersionText}" Margin="0,0,0,10" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
