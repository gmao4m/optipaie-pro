<Window x:Class="OptiPaie.Desktop.Views.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OptiPaie PRO — Activation"
        Height="640" Width="480" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" Background="{DynamicResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Brand header -->
        <Border Grid.Row="0" Background="{DynamicResource Brand}" Padding="28,26">
            <StackPanel>
                <Border Width="52" Height="52" CornerRadius="14" Background="#22FFFFFF" HorizontalAlignment="Left">
                    <Path Width="28" Height="28" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}"
                          Data="{StaticResource IconWallet}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding ProductName}" Foreground="{DynamicResource TextOnBrand}"
                           FontSize="24" FontWeight="SemiBold" Margin="0,14,0,0" />
                <TextBlock Text="{Binding Subtitle}" Foreground="#D8EFE7" Margin="0,3,0,0" FontSize="13.5" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <StackPanel Grid.Row="1" Margin="28,24">
            <TextBlock Text="Clé de licence" Style="{StaticResource Caption}" Margin="0,0,0,6" />
            <TextBox x:Name="KeyBox"
                     Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="KeyBox_TextChanged"
                     IsEnabled="{Binding IsNotBusy}"
                     CharacterCasing="Upper"
                     MaxLength="23"
                     FontFamily="Consolas" FontSize="18" FontWeight="SemiBold"
                     Height="46" Padding="12,0" VerticalContentAlignment="Center"
                     Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderStrong}"
                     BorderThickness="1" />
            <TextBlock Text="Format : XXXXX-XXXXX-XXXXX-XXXXX" Style="{StaticResource Caption}" Margin="2,6,0,0" />

            <Button Content="Activer la licence" Command="{Binding ActivateCommand}"
                    Style="{StaticResource PrimaryButton}" Height="44" Margin="0,16,0,0" />

            <!-- Status message -->
            <Border Margin="0,14,0,0" CornerRadius="8" Padding="12,10"
                    Visibility="{Binding StatusMessage, Converter={StaticResource EmptyToVis}}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BrandSoft}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                <Setter Property="Background" Value="#FCE8E6" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12.5">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Body}">
                            <Setter Property="Foreground" Value="{DynamicResource Salary}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsError}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Deduction}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Divider -->
            <Grid Margin="0,22,0,18">
                <Border Height="1" Background="{DynamicResource Border}" VerticalAlignment="Center" />
                <Border Background="{DynamicResource Canvas}" HorizontalAlignment="Center" Padding="10,0">
                    <TextBlock Text="OU" Style="{StaticResource Caption}" />
                </Border>
            </Grid>

            <!-- Trial -->
            <Border Style="{StaticResource Card}" Background="{DynamicResource SurfaceMuted}" Padding="16">
                <StackPanel>
                    <TextBlock Text="{Binding TrialInfoText}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}" />
                    <Button Content="{Binding TrialButtonText}" Command="{Binding TrialCommand}"
                            Style="{StaticResource SecondaryButton}" Height="42" Margin="0,14,0,0"
                            Visibility="{Binding CanStartTrial, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Border>

            <!-- Support contact (shown once the trial has ended) -->
            <Border Margin="0,16,0,0" CornerRadius="8" Padding="16" Background="#FCE8E6"
                    Visibility="{Binding IsTrialExpired, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Essai terminé" FontWeight="SemiBold" Foreground="{DynamicResource Deduction}"
                               FontSize="14" Margin="0,0,0,6" />
                    <TextBlock Text="{Binding SupportText}" TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}" FontSize="13" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
