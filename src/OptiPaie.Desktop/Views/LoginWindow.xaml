<Window x:Class="OptiPaie.Desktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="OptiPaie PRO — Connexion" Height="420" Width="420"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="{DynamicResource Canvas}">
    <Grid>
        <Border Style="{StaticResource Card}" Width="340" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="28">
            <StackPanel>
                <Border Width="46" Height="46" CornerRadius="12" Background="{DynamicResource Brand}" HorizontalAlignment="Center">
                    <Path Width="24" Height="24" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}" Data="{StaticResource IconWallet}"
                          HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding ProductName}" HorizontalAlignment="Center" Margin="0,12,0,0"
                           FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" />
                <TextBlock Text="{loc:Loc Login_Title}" HorizontalAlignment="Center" Margin="0,2,0,0"
                           FontSize="12.5" Foreground="{DynamicResource TextMuted}" />

                <TextBlock Style="{StaticResource Caption}" Margin="0,20,0,4" Text="{loc:Loc Login_Username}" />
                <TextBox x:Name="UsernameBox" Style="{StaticResource AppTextBox}"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,4" Text="{loc:Loc Login_Password}" />
                <PasswordBox x:Name="PasswordBox" Height="38" Padding="10,0" VerticalContentAlignment="Center"
                             Background="{DynamicResource Surface}" Foreground="{DynamicResource TextPrimary}"
                             BorderBrush="{DynamicResource BorderStrong}" FontFamily="{StaticResource AppFont}" FontSize="13.5" />

                <TextBlock Margin="0,10,0,0" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource Deduction}"
                           Text="{Binding StatusMessage}"
                           Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}" />

                <Button Style="{StaticResource PrimaryButton}" Margin="0,18,0,0" Content="{loc:Loc Login_SignIn}"
                        Command="{Binding LoginCommand}" IsDefault="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
