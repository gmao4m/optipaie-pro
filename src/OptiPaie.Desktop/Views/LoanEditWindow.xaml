<Window x:Class="OptiPaie.Desktop.Views.LoanEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="440" Width="470"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="Employé" />
            <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                      ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}"
                      IsEnabled="{Binding CanChooseEmployee}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding LastNameFr}" />
                            <Run Text="{Binding FirstNameFr}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="Type" />
                    <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                              ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}" DisplayMemberPath="Label" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="Montant (DA)" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Principal, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="Mensualité (DA)" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding MonthlyInstallment, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="Premier prélèvement" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <ComboBox Style="{StaticResource AppComboBox}" Width="110" Height="32"
                                  ItemsSource="{Binding Months}" SelectedValue="{Binding StartMonth}"
                                  SelectedValuePath="Value" DisplayMemberPath="Label" />
                        <ComboBox Style="{StaticResource AppComboBox}" Width="80" Height="32" Margin="6,0,0,0"
                                  ItemsSource="{Binding Years}" SelectedItem="{Binding StartYear}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Border Background="{DynamicResource BrandSoft}" CornerRadius="8" Padding="10,7" Margin="0,12,0,0">
                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextSecondary}" Text="{Binding ScheduleText}" />
            </Border>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="Motif / référence" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Enregistrer" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
