<UserControl x:Class="OptiPaie.Desktop.Views.ArchiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Archive" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="Consultez et réimprimez les bulletins archivés" />
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,20,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource Caption}" Text="Entreprise" Margin="0,0,0,5" />
                    <ComboBox Style="{StaticResource AppComboBox}" ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}" DisplayMemberPath="NameFr" />
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource Caption}" Text="Année" Margin="0,0,0,5" />
                    <ComboBox Style="{StaticResource AppComboBox}" ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                    <TextBlock Style="{StaticResource Caption}" Text="Mois" Margin="0,0,0,5" />
                    <ComboBox Style="{StaticResource AppComboBox}" ItemsSource="{Binding Months}" SelectedValue="{Binding SelectedMonth}" SelectedValuePath="Value" DisplayMemberPath="Label" />
                </StackPanel>
                <Button Grid.Column="3" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom" Content="Rechercher" Command="{Binding SearchCommand}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" Margin="0,16,0,0">
            <Grid>
                <ListBox BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Stretch"
                         ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Margin" Value="8,1" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="12,11">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceMuted}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="b" Property="Background" Value="{StaticResource BrandSoft}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource BrandSoft}" VerticalAlignment="Center">
                                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{StaticResource Brand}" Data="{StaticResource IconFileCheck}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding EmployeeName}" />
                                        <TextBlock Style="{StaticResource Caption}" Text="{Binding PeriodText}" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold" Foreground="{StaticResource Salary}" Text="{Binding NetText}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                    <Border Width="60" Height="60" CornerRadius="16" Background="{StaticResource SurfaceMuted}" HorizontalAlignment="Center">
                        <Path Width="28" Height="28" Stretch="Uniform" Fill="{StaticResource TextMuted}" Data="{StaticResource IconArchive}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Style="{StaticResource Caption}" Margin="0,14,0,0" HorizontalAlignment="Center" Text="Aucun bulletin pour cette période." />
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
            <Button Style="{StaticResource SecondaryButton}" Content="Aperçu" Command="{Binding PreviewCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Content="Imprimer" Command="{Binding PrintCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
