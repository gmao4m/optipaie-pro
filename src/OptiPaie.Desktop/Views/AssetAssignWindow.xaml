<Window x:Class="OptiPaie.Desktop.Views.AssetAssignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Attribuer le matériel" Height="360" Width="430"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{StaticResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="Attribuer le matériel" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="Employé" />
            <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                      ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding LastNameFr}" />
                            <Run Text="{Binding FirstNameFr}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="Date d'attribution" />
            <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding Date}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="État à la remise" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="Notes" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Attribuer" Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</Window>
