<Window x:Class="OptiPaie.Desktop.Views.AssetEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{Binding Title}" Height="470" Width="450"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc AssetEdit_Name}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Asset_Category}" />
                    <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                              ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}" DisplayMemberPath="Label" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Asset_Value}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding PurchaseValue, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Asset_Serial}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding SerialNumber, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc AssetEdit_AcquisitionDate}" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding PurchaseDate}" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Common_Notes}" />
            <TextBox Style="{StaticResource AppTextBox}" Height="52" Margin="0,4,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />

            <CheckBox Margin="0,12,0,0" IsChecked="{Binding IsShared}" Content="{loc:Loc Asset_SharedToggle}"
                      Foreground="{DynamicResource TextPrimary}" FontSize="12.5" VerticalContentAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
