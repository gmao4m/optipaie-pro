<Window x:Class="OptiPaie.Desktop.Views.CycleLaunchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lancer une campagne d'évaluation" Height="640" Width="640"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="Nouvelle campagne" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" TextWrapping="Wrap" Text="{Binding Hint}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,14,0,0">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Nom de la campagne" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="Type" />
                        <ComboBox Style="{StaticResource AppComboBox}" Height="38" Margin="0,4,0,0" ItemsSource="{Binding CycleTypes}" SelectedItem="{Binding CycleType}" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Début" />
                        <DatePicker Height="34" Margin="0,4,0,0" SelectedDate="{Binding StartDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="Fin" />
                        <DatePicker Height="34" Margin="0,4,0,0" SelectedDate="{Binding EndDate}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Style="{StaticResource Caption}" Text="Échéance" />
                        <DatePicker Height="34" Margin="0,4,0,0" SelectedDate="{Binding Deadline}" />
                    </StackPanel>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="Année" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding PeriodYear, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="Libellé période" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding PeriodLabel, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
                        <CheckBox Content="Auto-évaluation" IsChecked="{Binding SelfAssessment}" Margin="0,0,0,6" />
                    </StackPanel>
                </Grid>

                <TextBlock Style="{StaticResource Caption}" Margin="0,14,0,4" Text="Modèle par défaut (si le département n'en a pas)" />
                <ComboBox Style="{StaticResource AppComboBox}" Height="38" ItemsSource="{Binding Templates}" SelectedItem="{Binding FallbackTemplate}" />

                <TextBlock Style="{StaticResource Caption}" Margin="0,14,0,6" Text="Départements inclus" />
                <Border Style="{StaticResource Card}" Padding="12,8">
                    <ItemsControl ItemsSource="{Binding Departments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Margin="0,3" Content="{Binding Label}" IsChecked="{Binding IsChecked}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource AccentButton}" Margin="8,0,0,0" Content="Lancer la campagne" Command="{Binding LaunchCommand}" />
        </StackPanel>
    </Grid>
</Window>
