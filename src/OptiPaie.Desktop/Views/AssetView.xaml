<UserControl x:Class="OptiPaie.Desktop.Views.AssetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="RightText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Kpi" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,11" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="Matériel" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0"
                           Text="Suivez le matériel de l'entreprise et son attribution aux employés." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Company selection is global (header selector) -->

                <Button Style="{StaticResource PrimaryButton}" Height="32" Margin="10,0,0,0"
                        Content="Nouveau matériel" Command="{Binding NewCommand}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
            <Border Style="{StaticResource Kpi}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Disponibles" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Salary}" Text="{Binding AvailableText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Attribués" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Employer}" Text="{Binding AssignedText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Valeur totale (DA)" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding ValueText}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <DataGrid Grid.Row="2" Margin="0,18,0,0" ItemsSource="{Binding Assets}" SelectedItem="{Binding SelectedAsset}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="Segoe UI" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Matériel" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="Catégorie" Binding="{Binding CategoryLabel}" Width="120" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="N° série" Binding="{Binding SerialNumber}" Width="130" />
                <DataGridTextColumn Header="Valeur" Binding="{Binding ValueText}" Width="110" ElementStyle="{StaticResource RightText}" />
                <DataGridTextColumn Header="Détenteur" Binding="{Binding HolderName}" Width="180" />
                <DataGridTextColumn Header="Statut" Binding="{Binding StatusLabel}" Width="120" ElementStyle="{StaticResource CenterText}" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Historique" Command="{Binding HistoryCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Modifier" Command="{Binding EditCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Réparation" Command="{Binding RepairCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Réformer" Command="{Binding RetireCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Supprimer" Command="{Binding DeleteCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Retour" Command="{Binding ReturnCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Attribuer" Command="{Binding AssignCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
