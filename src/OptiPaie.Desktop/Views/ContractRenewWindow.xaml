<Window x:Class="OptiPaie.Desktop.Views.ContractRenewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Renouveler le contrat" Height="330" Width="430"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="Renouveler le contrat" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="Un nouveau contrat en vigueur sera créé et lié au précédent." />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="Nouveau début" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding NewStart}" />
                </StackPanel>
                <StackPanel Grid.Column="2" Visibility="{Binding ShowEndDate, Converter={StaticResource BoolVis}}">
                    <TextBlock Style="{StaticResource Caption}" Text="Nouvelle fin" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding NewEnd}" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="Nouveau salaire de base (DA)" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding NewSalaryText, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Renouveler" Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</Window>
