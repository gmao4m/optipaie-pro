<Window x:Class="OptiPaie.Desktop.Views.AssetHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Historique du matériel" Height="480" Width="720"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="{Binding AssetName}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" Text="{loc:Loc AssetHist_Title}" />
        </StackPanel>

        <DataGrid Grid.Row="1" Margin="0,16,0,0" ItemsSource="{Binding History}" AutoGenerateColumns="False"
                  HeadersVisibility="Column" IsReadOnly="True" CanUserAddRows="False" CanUserResizeRows="False"
                  GridLinesVisibility="All" RowHeight="30" FontFamily="{StaticResource AppFont}" FontSize="12.5"
                  Background="{DynamicResource Surface}" RowBackground="{DynamicResource Surface}"
                  AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Payroll_Employee}" Binding="{Binding EmployeeName}" Width="*" />
                <DataGridTextColumn Header="{loc:Loc AssetHist_AssignedOn}" Binding="{Binding AssignedDate, StringFormat=dd/MM/yyyy}" Width="110" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc AssetHist_ReturnedOn}" Binding="{Binding ReturnedDate, StringFormat=dd/MM/yyyy}" Width="110" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc AssetHist_CondOut}" Binding="{Binding ConditionOut}" Width="140" />
                <DataGridTextColumn Header="{loc:Loc AssetHist_CondIn}" Binding="{Binding ConditionIn}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" Content="{loc:Loc Common_Close}" Command="{Binding CloseCommand}" />
        </Grid>
    </Grid>
</Window>
