<UserControl x:Class="OptiPaie.Desktop.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,14" />
        </Style>

        <Style x:Key="Tile" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="100" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="12" Padding="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{DynamicResource BorderStrong}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TilePrimary" TargetType="Button">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Height" Value="100" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{DynamicResource Brand}" CornerRadius="12" Padding="16">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BrandHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource BrandPressed}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="{Binding Greeting}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{Binding Subtitle}" />
            </StackPanel>
            <Border HorizontalAlignment="Right" VerticalAlignment="Top" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="8" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TextSecondary}" Data="{StaticResource IconCalendar}" VerticalAlignment="Center" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" Text="{Binding MonthLabel}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Stats -->
        <UniformGrid Grid.Row="1" Rows="1" Columns="3" Margin="0,22,0,0">
            <Border Style="{StaticResource StatCard}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Entreprises" />
                    <TextBlock Style="{StaticResource Figure}" Margin="0,4,0,0" Text="{Binding Companies}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="6,0,6,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Employés" />
                    <TextBlock Style="{StaticResource Figure}" Margin="0,4,0,0" Text="{Binding Employees}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="Période en cours" />
                    <TextBlock Style="{StaticResource Figure}" Margin="0,4,0,0" Text="{Binding MonthLabel}" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Quick actions -->
        <StackPanel Grid.Row="2" Margin="0,22,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="Actions rapides" Margin="0,0,0,10" />
            <UniformGrid Rows="1" Columns="3">
                <Button Style="{StaticResource TilePrimary}" Command="{Binding NewPayrollCommand}" Margin="0,0,6,0">
                    <Grid>
                        <Path Width="24" Height="24" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}" Data="{StaticResource IconFile}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <DockPanel VerticalAlignment="Bottom">
                            <Path DockPanel.Dock="Right" Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}" Data="{StaticResource IconArrowRight}" VerticalAlignment="Center" />
                            <TextBlock Text="Établir une paie" FontWeight="SemiBold" Foreground="{DynamicResource TextOnBrand}" VerticalAlignment="Center" />
                        </DockPanel>
                    </Grid>
                </Button>
                <Button Style="{StaticResource Tile}" Command="{Binding NewEmployeeCommand}" Margin="6,0,6,0">
                    <Grid>
                        <Path Width="24" Height="24" Stretch="Uniform" Fill="{DynamicResource Brand}" Data="{StaticResource IconUserPlus}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <TextBlock Text="Nouvel employé" FontWeight="SemiBold" VerticalAlignment="Bottom" />
                    </Grid>
                </Button>
                <Button Style="{StaticResource Tile}" Command="{Binding ArchiveCommand}" Margin="6,0,0,0">
                    <Grid>
                        <Path Width="24" Height="24" Stretch="Uniform" Fill="{DynamicResource Brand}" Data="{StaticResource IconArchive}" HorizontalAlignment="Left" VerticalAlignment="Top" />
                        <TextBlock Text="Archive des paies" FontWeight="SemiBold" VerticalAlignment="Bottom" />
                    </Grid>
                </Button>
            </UniformGrid>
        </StackPanel>

        <!-- Recent activity -->
        <StackPanel Grid.Row="3" Margin="0,22,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="Activité récente" Margin="0,0,0,10" />
            <Border Style="{StaticResource Card}" Padding="0">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Recent}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="52">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                        <Border Width="30" Height="30" CornerRadius="8" Background="{DynamicResource BrandSoft}" VerticalAlignment="Center">
                                            <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource Brand}" Data="{StaticResource IconFileCheck}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" />
                                            <TextBlock Style="{StaticResource Caption}" Text="{Binding Subtitle}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Text="{Binding When}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0" />
                                    <Border Height="1" VerticalAlignment="Bottom" Background="{DynamicResource Border}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="16,18" HorizontalAlignment="Center" Style="{StaticResource Caption}"
                               Text="L'activité récente de vos paies apparaîtra ici."
                               Visibility="{Binding HasRecent, Converter={StaticResource InverseBoolToVis}}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
