<Window x:Class="OptiPaie.Desktop.Views.TrainingParticipantsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Participants" Height="520" Width="760"
        WindowStartupLocation="CenterOwner" Background="{StaticResource Canvas}">
    <Window.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
    </Window.Resources>

    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="{Binding SessionTitle}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" Text="Participants et résultats" />
        </StackPanel>

        <!-- Enrol -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Inscrire :" VerticalAlignment="Center" Foreground="{StaticResource TextSecondary}" FontSize="12.5" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="240" Height="30" Margin="10,0,0,0"
                          ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Run Text="{Binding LastNameFr}" />
                                <Run Text="{Binding FirstNameFr}" />
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Style="{StaticResource SecondaryButton}" Height="30" Margin="8,0,0,0"
                        Content="Inscrire" Command="{Binding EnrollCommand}" />
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" Margin="0,12,0,0" ItemsSource="{Binding Participants}" SelectedItem="{Binding SelectedParticipant}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" CanUserAddRows="False" CanUserResizeRows="False"
                  GridLinesVisibility="All" RowHeight="34" FontFamily="Segoe UI" FontSize="12.5"
                  Background="{StaticResource Surface}" RowBackground="{StaticResource Surface}"
                  AlternatingRowBackground="{StaticResource SurfaceMuted}"
                  BorderBrush="{StaticResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{StaticResource Border}" VerticalGridLinesBrush="{StaticResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Employé" Binding="{Binding EmployeeName}" Width="*" IsReadOnly="True" />
                <DataGridTemplateColumn Header="Résultat" Width="130">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding Results}" SelectedItem="{Binding Result, UpdateSourceTrigger=PropertyChanged}"
                                      DisplayMemberPath="Label" BorderThickness="0" Background="Transparent" VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Note" Binding="{Binding Score, UpdateSourceTrigger=LostFocus}" Width="90" />
                <DataGridTextColumn Header="Attestation" Binding="{Binding CertificateRef, UpdateSourceTrigger=LostFocus}" Width="180" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Retirer" Command="{Binding RemoveCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Fermer" Command="{Binding CloseCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
