<UserControl x:Class="OptiPaie.Desktop.Views.EmployeesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="{loc:Loc Shell_Nav_Employees}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{loc:Loc Employees_Subtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Company selection is global (header selector) -->

                <Button Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Command="{Binding NewCommand}"
                        Content="{loc:Loc Employees_New}" />
            </StackPanel>
        </Grid>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- List -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12">
                        <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="34,0,10,0" />
                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TextMuted}" Data="{StaticResource IconSearch}"
                              HorizontalAlignment="Left" VerticalAlignment="Center" Margin="11,0,0,0" IsHitTestVisible="False" />
                        <TextBlock Text="{loc:Loc Employees_SearchPlaceholder}" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="34,0,0,0"
                                   IsHitTestVisible="False" Visibility="{Binding Search, Converter={StaticResource EmptyToVis}}" />
                    </Grid>

                    <ListBox Grid.Row="1" BorderThickness="0" Background="Transparent"
                             ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             HorizontalContentAlignment="Stretch">
                        <ListBox.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenProfileCommand}" />
                        </ListBox.InputBindings>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="6,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="10,9">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource BrandSoft}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel HorizontalAlignment="Left">
                                        <TextBlock FontWeight="SemiBold">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} {1}">
                                                    <Binding Path="LastNameFr" />
                                                    <Binding Path="FirstNameFr" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Style="{StaticResource Caption}" Text="{Binding Poste}" />
                                    </StackPanel>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{DynamicResource TextSecondary}" FontSize="12.5"
                                               Text="{Binding BaseSalary, StringFormat={}{0:N0} DA}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Detail -->
            <Grid Grid.Column="1" Margin="16,0,0,0">
                <!-- Empty state -->
                <Border Style="{StaticResource Card}" Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="16" Background="{DynamicResource SurfaceMuted}" HorizontalAlignment="Center">
                            <Path Width="28" Height="28" Stretch="Uniform" Fill="{DynamicResource TextMuted}" Data="{StaticResource IconUsers}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Style="{StaticResource Caption}" Margin="0,14,0,0" HorizontalAlignment="Center" Text="{loc:Loc Employees_EmptyState}" />
                    </StackPanel>
                </Border>

                <!-- Profile + actions -->
                <DockPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding DeleteCommand}" Content="{loc:Loc Common_Delete}" Foreground="{DynamicResource Deduction}" />
                        <Button Style="{StaticResource SecondaryButton}" Margin="12,0,0,0" Command="{Binding EditCommand}" Content="{loc:Loc Common_Edit}" />
                        <Button Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Command="{Binding OpenProfileCommand}" Content="{loc:Loc Profile_Title}" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Padding="24" VerticalAlignment="Top">
                    <StackPanel DataContext="{Binding SelectedEmployee}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="52" Height="52" CornerRadius="26" Background="{DynamicResource BrandSoft}">
                                <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource BrandText}"
                                           Text="{Binding Converter={StaticResource Initials}}" />
                            </Border>
                            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Style="{StaticResource H2}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} {1}">
                                            <Binding Path="LastNameFr" />
                                            <Binding Path="FirstNameFr" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource Caption}" Text="{Binding ContractType, Converter={StaticResource EnumFr}}" />
                            </StackPanel>
                        </StackPanel>

                        <Border Height="1" Background="{DynamicResource Border}" Margin="0,18" />

                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,16,16">
                                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_Nss}" />
                                <TextBlock Margin="0,3,0,0" Text="{Binding Nss, TargetNullValue=—}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_Poste}" />
                                <TextBlock Margin="0,3,0,0" Text="{Binding Poste, TargetNullValue=—}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,16">
                                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_Category}" />
                                <TextBlock Margin="0,3,0,0" Text="{Binding Category, TargetNullValue=—}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_HireDate}" />
                                <TextBlock Margin="0,3,0,0" Text="{Binding HireDate, StringFormat={}{0:dd/MM/yyyy}}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,16,16">
                                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_BaseSalary}" />
                                <TextBlock Margin="0,3,0,0" FontWeight="SemiBold" Foreground="{DynamicResource Salary}" Text="{Binding BaseSalary, StringFormat={}{0:N2} DA}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_PaymentMode}" />
                                <TextBlock Margin="0,3,0,0" Text="{Binding PaymentMode, Converter={StaticResource EnumFr}}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                    </Border>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
