<Window x:Class="OptiPaie.Desktop.Views.TrainingEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Height="470" Width="460"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{StaticResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="Intitulé" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding SessionTitle, UpdateSourceTrigger=PropertyChanged}" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="Domaine" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="Organisme" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Provider, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="Date de début" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding StartDate}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="Date de fin" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding EndDate}" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="Lieu" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="Coût (DA)" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Cost, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="Notes" />
            <TextBox Style="{StaticResource AppTextBox}" Height="48" Margin="0,4,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Enregistrer" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
