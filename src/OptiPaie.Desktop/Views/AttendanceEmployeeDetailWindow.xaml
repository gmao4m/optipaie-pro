<Window x:Class="OptiPaie.Desktop.Views.AttendanceEmployeeDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique de présence" Height="600" Width="560"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H2}" Text="{Binding EmployeeName}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" Text="{Binding PeriodLabel}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Style="{StaticResource SecondaryButton}" Height="30" Content="◀" Command="{Binding PrevCommand}" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="120" Height="30" Margin="6,0,0,0"
                          ItemsSource="{Binding Months}" SelectedValue="{Binding SelectedMonth}"
                          SelectedValuePath="Value" DisplayMemberPath="Label" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="80" Height="30" Margin="6,0,0,0"
                          ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
                <Button Style="{StaticResource SecondaryButton}" Height="30" Margin="6,0,0,0" Content="▶" Command="{Binding NextCommand}" />
            </StackPanel>
        </Grid>

        <!-- Weekday headers -->
        <ItemsControl Grid.Row="1" ItemsSource="{Binding WeekdayHeaders}" Margin="0,14,0,0">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" HorizontalAlignment="Center" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Calendar -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Days}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><UniformGrid Columns="7" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Margin="2" Height="58" CornerRadius="6" Background="{Binding Background}"
                            BorderBrush="{DynamicResource Border}" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="{Binding DayText}" Margin="6,4,0,0" FontSize="12"
                                       HorizontalAlignment="Left" VerticalAlignment="Top" Foreground="{DynamicResource TextSecondary}" />
                            <TextBlock Text="{Binding Letter}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="16" FontWeight="SemiBold" Foreground="#1B2430" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Stats -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="14,12" VerticalAlignment="Top">
            <StackPanel>
                <TextBlock Text="Statistiques du mois" FontWeight="SemiBold" Margin="0,0,0,6" />
                <TextBlock Text="{Binding StatsText}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" FontSize="12.5" />
                <TextBlock Text="{Binding LateText}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="{DynamicResource Warning}" FontSize="12.5" />
                <TextBlock Text="{Binding AbsenceText}" TextWrapping="Wrap" Margin="0,4,0,0" Foreground="{DynamicResource Deduction}" FontSize="12.5" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Style="{StaticResource PrimaryButton}" Content="Fermer" Command="{Binding CloseCommand}" />
        </StackPanel>
    </Grid>
</Window>
