<UserControl x:Class="OptiPaie.Desktop.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="Évaluations" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0"
                           Text="Chaque évaluation reflète automatiquement la présence de l'employé." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Company selection is global (header selector) -->

                <ComboBox Style="{StaticResource AppComboBox}" Width="90" Height="32" Margin="10,0,0,0" VerticalAlignment="Center"
                          ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
                <Button Style="{StaticResource PrimaryButton}" Height="32" Margin="10,0,0,0"
                        Content="Nouvelle évaluation" Command="{Binding NewCommand}" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1" Margin="0,18,0,0" ItemsSource="{Binding Reviews}" SelectedItem="{Binding SelectedReview}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="Segoe UI" FontSize="12.5" Background="{StaticResource Surface}"
                  RowBackground="{StaticResource Surface}" AlternatingRowBackground="{StaticResource SurfaceMuted}"
                  BorderBrush="{StaticResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{StaticResource Border}" VerticalGridLinesBrush="{StaticResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Employé" Binding="{Binding EmployeeName}" Width="*" />
                <DataGridTextColumn Header="Période" Binding="{Binding PeriodLabel}" Width="120" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="Évaluateur" Binding="{Binding Reviewer}" Width="160" />
                <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="100" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="Note" Binding="{Binding ScoreText}" Width="90" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="Appréciation" Binding="{Binding Rating}" Width="120" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="Statut" Binding="{Binding StatusLabel}" Width="100" ElementStyle="{StaticResource CenterText}" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Ouvrir" Command="{Binding OpenCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Rouvrir" Command="{Binding ReopenCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Supprimer" Command="{Binding DeleteCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Finaliser" Command="{Binding CompleteCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
