<UserControl x:Class="OptiPaie.Desktop.Views.PerformanceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="Center" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="AppGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="All" />
            <Setter Property="RowHeight" Value="32" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Background" Value="{StaticResource Surface}" />
            <Setter Property="RowBackground" Value="{StaticResource Surface}" />
            <Setter Property="AlternatingRowBackground" Value="{StaticResource SurfaceMuted}" />
            <Setter Property="BorderBrush" Value="{StaticResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Border}" />
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Border}" />
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource GridHeader}" />
        </Style>
        <Style x:Key="Bar" TargetType="ProgressBar">
            <Setter Property="Height" Value="7" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="Foreground" Value="{StaticResource Accent}" />
            <Setter Property="Background" Value="{StaticResource SurfaceMuted}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="8,2" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="Performance &amp; Carrière" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0"
                           Text="Campagnes d'évaluation, modèles, objectifs, calibrage et parcours des employés." />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <TextBlock Text="Année" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,8,0" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="90" Height="32" ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="1" Margin="0,16,0,0" Background="Transparent" BorderThickness="0">

            <!-- ============================================ Campagnes -->
            <TabItem Header="Campagnes">
                <Grid DataContext="{Binding Cycles}" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" Text="{Binding StatusMessage}" />
                        <Button Style="{StaticResource AccentButton}" HorizontalAlignment="Right" Height="34" Content="Lancer une campagne" Command="{Binding LaunchCommand}" />
                    </Grid>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- Cycle list -->
                        <ListBox Grid.Column="0" BorderThickness="1" BorderBrush="{StaticResource Border}" Background="{StaticResource Surface}"
                                 ItemsSource="{Binding Cycles}" SelectedItem="{Binding SelectedCycle}" HorizontalContentAlignment="Stretch">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="2,6">
                                        <DockPanel>
                                            <Border DockPanel.Dock="Right" Style="{StaticResource Chip}" Background="{Binding StatusBrush}">
                                                <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13.5" TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding TypeLabel}" FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,2,0,4" />
                                        <ProgressBar Style="{StaticResource Bar}" Value="{Binding CompletionValue}" />
                                        <TextBlock Text="{Binding CompletionText}" FontSize="11" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" />
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Cycle detail -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ItemsControl Grid.Row="0" ItemsSource="{Binding Departments}" Margin="0,0,0,10">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Card}" Padding="12,8" Margin="0,0,8,8" Width="180">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Department}" FontWeight="SemiBold" FontSize="12.5" />
                                                <ProgressBar Style="{StaticResource Bar}" Margin="0,5,0,3" Value="{Binding CompletionValue}" />
                                                <TextBlock Text="{Binding CompletionText}" FontSize="11" Foreground="{StaticResource TextMuted}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <DataGrid Grid.Row="1" Style="{StaticResource AppGrid}" ItemsSource="{Binding Reviews}" SelectedItem="{Binding SelectedReview}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Employé" Binding="{Binding EmployeeName}" Width="*" />
                                    <DataGridTextColumn Header="Département" Binding="{Binding Department}" Width="140" />
                                    <DataGridTextColumn Header="Évaluateur" Binding="{Binding Reviewer}" Width="140" />
                                    <DataGridTextColumn Header="Note" Binding="{Binding ScoreText}" Width="150" />
                                    <DataGridTextColumn Header="Statut" Binding="{Binding StatusLabel}" Width="90" ElementStyle="{StaticResource Center}" />
                                    <DataGridTextColumn Header="Échéance" Binding="{Binding DueText}" Width="90" ElementStyle="{StaticResource Center}" />
                                </DataGrid.Columns>
                            </DataGrid>
                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                                <Button Style="{StaticResource SecondaryButton}" Content="Supprimer" Command="{Binding DeleteCommand}" />
                                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Ouvrir l'évaluation" Command="{Binding OpenReviewCommand}" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================================ Évaluations -->
            <TabItem Header="Évaluations">
                <Grid Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" Style="{StaticResource AppGrid}" ItemsSource="{Binding Reviews}" SelectedItem="{Binding SelectedReview}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Employé" Binding="{Binding EmployeeName}" Width="*" />
                            <DataGridTextColumn Header="Période" Binding="{Binding PeriodLabel}" Width="110" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Évaluateur" Binding="{Binding Reviewer}" Width="150" />
                            <DataGridTextColumn Header="Date" Binding="{Binding DateText}" Width="100" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Note" Binding="{Binding ScoreText}" Width="90" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Appréciation" Binding="{Binding Rating}" Width="120" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Statut" Binding="{Binding StatusLabel}" Width="100" ElementStyle="{StaticResource Center}" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButton}" Content="Nouvelle évaluation" Command="{Binding NewCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Rouvrir" Command="{Binding ReopenCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Supprimer" Command="{Binding DeleteCommand}" />
                            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Ouvrir" Command="{Binding OpenCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================================ Modèles -->
            <TabItem Header="Modèles">
                <Grid DataContext="{Binding Modeles}" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource Caption}" Text="{Binding StatusMessage}" />
                    <ScrollViewer Grid.Row="1" Margin="0,10,0,0" VerticalScrollBarVisibility="Auto">
                        <ListBox ItemsSource="{Binding Templates}" SelectedItem="{Binding Selected}" BorderThickness="0" Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,12,12" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="bd" Width="240" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}"
                                                        BorderThickness="1" CornerRadius="12" Padding="16" Cursor="Hand">
                                                    <StackPanel>
                                                        <DockPanel>
                                                            <Border DockPanel.Dock="Right" Style="{StaticResource Chip}" Background="{Binding OriginBrush}">
                                                                <TextBlock Text="{Binding OriginText}" Foreground="White" FontSize="10.5" FontWeight="SemiBold" />
                                                            </Border>
                                                            <Border Width="34" Height="34" CornerRadius="9" Background="{StaticResource BrandSoft}">
                                                                <Path Width="17" Height="17" Stretch="Uniform" Fill="{StaticResource Brand}" Data="{StaticResource IconFileCheck}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                            </Border>
                                                        </DockPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Margin="0,10,0,0" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding KindLabel}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" />
                                                        <TextBlock Text="{Binding DepartmentTag}" FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" />
                                                        <TextBlock Text="{Binding CriteriaText}" FontSize="11.5" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" />
                                                    </StackPanel>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                                                        <Setter TargetName="bd" Property="BorderThickness" Value="2" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Content="Supprimer" Command="{Binding DeleteCommand}" />
                        <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Modifier" Command="{Binding EditCommand}" />
                        <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Dupliquer" Command="{Binding DuplicateCommand}" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ============================================ Tableau de bord -->
            <TabItem Header="Tableau de bord">
                <ScrollViewer DataContext="{Binding Dashboard}" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Style="{StaticResource H2}" Text="{Binding Headline}" />
                        <TextBlock Style="{StaticResource Caption}" Margin="0,14,0,0" Text="Aucune donnée à afficher pour le moment."
                                   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
                        <Grid Margin="0,14,0,0" Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Meilleurs 10 %" FontWeight="SemiBold" Foreground="{StaticResource Salary}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding Top}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="34">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding EmployeeName}" FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Text="{Binding Department}" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="SemiBold" Foreground="{Binding Brush}" Text="{Binding PercentText}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="À accompagner (10 % les plus bas)" FontWeight="SemiBold" Foreground="{StaticResource Deduction}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding Bottom}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Height="34">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding EmployeeName}" FontWeight="SemiBold" FontSize="13" />
                                                        <TextBlock Text="{Binding Department}" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="8,0,0,0" VerticalAlignment="Center" />
                                                    </StackPanel>
                                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" FontWeight="SemiBold" Foreground="{Binding Brush}" Text="{Binding PercentText}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Border Style="{StaticResource Card}" Padding="16" Margin="0,14,0,0" Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="Moyenne par département" FontWeight="SemiBold" Margin="0,0,0,10" />
                                <ItemsControl ItemsSource="{Binding Departments}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="30">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="70" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Department}" VerticalAlignment="Center" FontSize="12.5" />
                                                <ProgressBar Grid.Column="1" Style="{StaticResource Bar}" VerticalAlignment="Center" Foreground="{Binding Brush}" Value="{Binding BarValue}" />
                                                <TextBlock Grid.Column="2" Text="{Binding AverageText}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12.5" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Tendance annuelle" FontWeight="SemiBold" Margin="0,16,0,10" />
                                <ItemsControl ItemsSource="{Binding Trend}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Height="30">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="160" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="70" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center" FontSize="12.5" />
                                                <ProgressBar Grid.Column="1" Style="{StaticResource Bar}" VerticalAlignment="Center" Value="{Binding BarValue}" />
                                                <TextBlock Grid.Column="2" Text="{Binding AverageText}" HorizontalAlignment="Right" VerticalAlignment="Center" FontFamily="Consolas" FontSize="12.5" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============================================ Calibrage -->
            <TabItem Header="Calibrage">
                <Grid DataContext="{Binding Calibration}" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{Binding Headline}" />
                    <TextBlock Grid.Row="1" Style="{StaticResource Caption}" Margin="0,14,0,0" Text="Aucune évaluation finalisée pour cette année."
                               Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}" />
                    <DataGrid Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource AppGrid}" RowHeight="38" ItemsSource="{Binding Departments}"
                              Visibility="{Binding HasData, Converter={StaticResource BoolToVis}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Département" Binding="{Binding Department}" Width="*" />
                            <DataGridTextColumn Header="Évals" Binding="{Binding CountText}" Width="70" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Moyenne" Binding="{Binding AverageText}" Width="90" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Écart" Binding="{Binding DeltaText}" Width="90" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Insuff." Binding="{Binding D0}" Width="70" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="A. bien" Binding="{Binding D1}" Width="70" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Bien" Binding="{Binding D2}" Width="60" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="T. bien" Binding="{Binding D3}" Width="70" ElementStyle="{StaticResource Center}" />
                            <DataGridTextColumn Header="Excel." Binding="{Binding D4}" Width="70" ElementStyle="{StaticResource Center}" />
                            <DataGridTemplateColumn Header="Alerte" Width="110">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Chip}" Background="{Binding OutlierBrush}" Visibility="{Binding IsOutlier, Converter={StaticResource BoolToVis}}" Margin="6,0">
                                            <TextBlock Text="{Binding OutlierText}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- ============================================ Objectifs -->
            <TabItem Header="Objectifs">
                <Grid DataContext="{Binding Objectifs}" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <DataGrid Grid.Row="0" Style="{StaticResource AppGrid}" RowHeight="40" ItemsSource="{Binding Goals}" SelectedItem="{Binding Selected}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Employé" Binding="{Binding EmployeeName}" Width="150" />
                            <DataGridTextColumn Header="Objectif" Binding="{Binding Title}" Width="*" />
                            <DataGridTextColumn Header="Cible" Binding="{Binding TargetMetric}" Width="140" />
                            <DataGridTextColumn Header="Échéance" Binding="{Binding DueText}" Width="90" ElementStyle="{StaticResource Center}" />
                            <DataGridTemplateColumn Header="Progression" Width="150">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="8,0">
                                            <ProgressBar Style="{StaticResource Bar}" Value="{Binding ProgressValue}" />
                                            <TextBlock Text="{Binding ProgressText}" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,3,0,0" HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Statut" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource Chip}" Background="{Binding StatusBrush}" Margin="6,0">
                                            <TextBlock Text="{Binding StatusLabel}" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Grid Grid.Row="1" Margin="0,12,0,0">
                        <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButton}" Content="Supprimer" Command="{Binding DeleteCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Marquer atteint" Command="{Binding AchieveCommand}" />
                            <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Modifier" Command="{Binding EditCommand}" />
                            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Nouvel objectif" Command="{Binding NewCommand}" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============================================ Comparaison -->
            <TabItem Header="Comparaison">
                <Grid DataContext="{Binding Comparaison}" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource Caption}" Text="Employés" Margin="0,0,0,6" />
                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="10,6">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Employees}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Margin="0,3" IsChecked="{Binding IsChecked}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="12.5" />
                                                    <TextBlock Text="{Binding Department}" FontSize="10.5" Foreground="{StaticResource TextMuted}" />
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Style="{StaticResource SecondaryButton}" Content="Effacer" Command="{Binding ClearCommand}" />
                            <Button Style="{StaticResource AccentButton}" Margin="8,0,0,0" Content="Comparer" Command="{Binding CompareCommand}" />
                        </StackPanel>
                    </Grid>
                    <ScrollViewer Grid.Column="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Columns}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource Card}" Width="220" Margin="0,0,12,0" Padding="16">
                                        <StackPanel>
                                            <TextBlock Text="{Binding EmployeeName}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Poste}" FontSize="11.5" Foreground="{StaticResource TextSecondary}" />
                                            <TextBlock Text="{Binding Department}" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10" />
                                            <TextBlock Text="Dernière note" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0" />
                                            <TextBlock Text="{Binding LatestText}" FontFamily="Consolas" FontSize="20" FontWeight="Bold" Foreground="{Binding Brush}" />
                                            <TextBlock Text="{Binding Rating}" FontSize="12" Foreground="{StaticResource TextSecondary}" />
                                            <TextBlock Text="Moyenne" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,10,0,0" />
                                            <TextBlock Text="{Binding AverageText}" FontFamily="Consolas" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="Évaluations" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding ReviewCountText}" FontSize="14" FontWeight="SemiBold" />
                                            <TextBlock Text="Objectifs" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding GoalsText}" FontSize="12.5" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ============================================ Parcours -->
            <TabItem Header="Parcours">
                <Grid DataContext="{Binding Parcours}" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <TextBlock Text="Employé" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0,0,8,0" />
                            <ComboBox Style="{StaticResource AppComboBox}" Width="240" Height="34" ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}" DisplayMemberPath="Name" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SecondaryButton}" Content="+ Récompense" Command="{Binding RewardCommand}" />
                            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="+ Promotion" Command="{Binding PromotionCommand}" />
                        </StackPanel>
                    </Grid>
                    <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0" Margin="0,14,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Items}" Margin="16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="96" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding DateText}" FontFamily="Consolas" FontSize="12" Foreground="{StaticResource TextMuted}" VerticalAlignment="Top" Margin="0,10,0,0" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Stretch" HorizontalAlignment="Center" Margin="6,0,14,0">
                                                <Border Width="12" Height="12" CornerRadius="6" Background="{Binding KindBrush}" Margin="0,12,0,0" />
                                                <Border Width="2" Background="{StaticResource Border}" HorizontalAlignment="Center" Height="40" />
                                            </StackPanel>
                                            <Border Grid.Column="2" Background="{StaticResource SurfaceMuted}" CornerRadius="8" Padding="12,10" Margin="0,4,0,4">
                                                <StackPanel>
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" Style="{StaticResource Chip}" Background="{Binding KindBrush}">
                                                            <TextBlock Text="{Binding KindLabel}" Foreground="White" FontSize="10.5" FontWeight="SemiBold" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="13.5" TextTrimming="CharacterEllipsis" />
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Detail}" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,3,0,0" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding ValueText}" FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
