<Window x:Class="OptiPaie.Desktop.Views.ModuleActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Activer un module"
        Height="360" Width="460" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" Background="{DynamicResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <Grid Margin="26,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
            <Border Width="40" Height="40" CornerRadius="11" Background="{DynamicResource BrandSoft}">
                <Path Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource Brand}"
                      Data="{StaticResource IconLock}" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Activer un module" Style="{StaticResource H2}" />
                <TextBlock Text="Saisissez votre clé d'activation de module" Style="{StaticResource Caption}" />
            </StackPanel>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="Clé d'activation" Style="{StaticResource Caption}" Margin="0,18,0,6" />
        <TextBox Grid.Row="2" x:Name="KeyBox"
                 Text="{Binding Key, UpdateSourceTrigger=PropertyChanged}"
                 IsEnabled="{Binding IsNotBusy}" CharacterCasing="Upper"
                 FontFamily="Consolas" FontSize="16" FontWeight="SemiBold"
                 Height="44" Padding="12,0" VerticalContentAlignment="Center"
                 Background="{DynamicResource Surface}" BorderBrush="{DynamicResource BorderStrong}" BorderThickness="1" />
        <TextBlock Grid.Row="3" Text="Format : MOD-XXXXX-XXXXX-XXXXX-XXXXX" Style="{StaticResource Caption}" Margin="2,6,0,0" />

        <!-- Status -->
        <Border Grid.Row="4" VerticalAlignment="Top" Margin="0,16,0,0" CornerRadius="8" Padding="12,10"
                Visibility="{Binding StatusMessage, Converter={StaticResource EmptyToVis}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource BrandSoft}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsError}" Value="True">
                            <Setter Property="Background" Value="#FCE8E6" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" FontSize="12.5">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource Body}">
                        <Setter Property="Foreground" Value="{DynamicResource Salary}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsError}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource Deduction}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuler" Style="{StaticResource SecondaryButton}" Height="40"
                    IsEnabled="{Binding IsNotBusy}" Click="Cancel_Click" Margin="0,0,10,0" />
            <Button Content="{Binding ButtonText}" Command="{Binding ActivateCommand}"
                    Style="{StaticResource PrimaryButton}" Height="40" MinWidth="150" />
        </StackPanel>
    </Grid>
</Window>
