<UserControl x:Class="OptiPaie.Desktop.Views.AtsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization">
    <UserControl.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Kpi" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,11" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="{loc:Loc Ats_Title}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{loc:Loc Ats_Subtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Company selection is global (header selector) -->

                <Button Style="{StaticResource PrimaryButton}" Height="32" Margin="10,0,0,0"
                        Content="{loc:Loc Ats_New}" Command="{Binding NewCommand}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
            <Border Style="{StaticResource Kpi}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Ats_OpenPostings}" />
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Employer}" Text="{Binding OpenText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Dashboard_Kpi_Candidates}" />
                    <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="20" FontWeight="SemiBold" Text="{Binding CandidatesText}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <DataGrid x:Name="PostingsGrid" Grid.Row="2" Margin="0,18,0,0" ItemsSource="{Binding Postings}" SelectedItem="{Binding SelectedPosting}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="{StaticResource AppFont}" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Employee_Poste}" Binding="{Binding Title}" Width="*" />
                <DataGridTextColumn Header="{loc:Loc Users_ColDepartment}" Binding="{Binding Department}" Width="160" />
                <DataGridTextColumn Header="{loc:Loc Ats_OpenedOn}" Binding="{Binding OpenText}" Width="110" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc Ats_Positions}" Binding="{Binding PositionsText}" Width="80" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc Ats_Recruited}" Binding="{Binding CandidatesText}" Width="90" ElementStyle="{StaticResource CenterText}" />
                <DataGridTemplateColumn Header="{loc:Loc Common_Status}" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusPill}">
                                <TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource EmptyStateMessage}" Text="{loc:Loc Msg_NoData}"
                   Visibility="{Binding HasItems, ElementName=PostingsGrid, Converter={StaticResource InverseBoolToVis}}" />

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Edit}" Command="{Binding EditCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Ats_CloseOffer}" Command="{Binding CloseCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Ats_Reopen}" Command="{Binding ReopenCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Delete}" Command="{Binding DeleteCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Dashboard_Kpi_Candidates}" Command="{Binding PipelineCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
