<Window x:Class="OptiPaie.Desktop.Views.AssetReturnWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Retour du matériel" Height="330" Width="410"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{loc:Loc AssetReturn_Title}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <!-- Shown only for a shared asset held by several employees. -->
            <StackPanel Visibility="{Binding HasHolderChoice, Converter={StaticResource BoolToVis}}" Margin="0,0,0,12">
                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc AssetReturn_Holder}" />
                <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                          ItemsSource="{Binding Holders}" SelectedItem="{Binding SelectedHolder}" DisplayMemberPath="EmployeeName" />
            </StackPanel>

            <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc AssetReturn_Date}" />
            <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding Date}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc AssetReturn_Condition}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc AssetReturn_Save}" Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</Window>
