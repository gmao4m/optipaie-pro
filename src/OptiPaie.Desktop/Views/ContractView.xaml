<UserControl x:Class="OptiPaie.Desktop.Views.ContractView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization">
    <UserControl.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="RightText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Kpi" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,11" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="{loc:Loc Contract_Title}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{loc:Loc Contract_Subtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Company selection is global (header selector) -->

                <Button Style="{StaticResource PrimaryButton}" Height="32" Margin="10,0,0,0"
                        Content="{loc:Loc Contract_New}" Command="{Binding NewCommand}" />
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
            <Border Style="{StaticResource Kpi}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Dashboard_Kpi_ActiveContracts}" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Salary}" Text="{Binding ActiveCountText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Kpi}">
                <StackPanel>
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Contract_ToRenew}" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Warning}" Text="{Binding ExpiringCountText}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <DataGrid Grid.Row="2" Margin="0,18,0,0" ItemsSource="{Binding Contracts}" SelectedItem="{Binding SelectedContract}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="Segoe UI" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Payroll_Employee}" Binding="{Binding EmployeeName}" Width="*" />
                <DataGridTextColumn Header="{loc:Loc Common_Type}" Binding="{Binding TypeLabel}" Width="90" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc Employee_Poste}" Binding="{Binding Position}" Width="150" />
                <DataGridTextColumn Header="{loc:Loc Contract_Salary}" Binding="{Binding SalaryText}" Width="110" ElementStyle="{StaticResource RightText}" />
                <DataGridTextColumn Header="{loc:Loc Loan_Start}" Binding="{Binding StartText}" Width="95" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc Contract_End}" Binding="{Binding EndText}" Width="95" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc Contract_Expiry}" Binding="{Binding ExpiryText}" Width="110" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc Common_Status}" Binding="{Binding StatusLabel}" Width="105" ElementStyle="{StaticResource CenterText}" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="PDF" Command="{Binding PdfCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Edit}" Command="{Binding EditCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Contract_Terminate}" Command="{Binding TerminateCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Contract_Renew}" Command="{Binding RenewCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Delete}" Command="{Binding DeleteCommand}" />
                <Button Style="{StaticResource AccentButton}" Margin="8,0,0,0" Content="{loc:Loc Contract_Activate}" Command="{Binding ActivateCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
