<Window x:Class="OptiPaie.Desktop.Views.CertificateEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{Binding Title}" Height="470" Width="460"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Payroll_Employee}" />
            <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                      ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}"
                      IsEnabled="{Binding CanChooseEmployee}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding LastNameFr}" />
                            <Run Text="{Binding FirstNameFr}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc CertEdit_Type}" />
                    <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                              ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}" DisplayMemberPath="Label" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Recent_Date}" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding IssueDate}" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc CertEdit_Reference}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc CertEdit_Purpose}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Purpose, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Visibility="{Binding IsCustom, Converter={StaticResource BoolVis}}">
                <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc CertEdit_Body}" />
                <TextBox Style="{StaticResource AppTextBox}" Height="80" Margin="0,4,0,0"
                         AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                         Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
