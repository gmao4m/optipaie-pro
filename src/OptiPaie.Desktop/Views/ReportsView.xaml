<UserControl x:Class="OptiPaie.Desktop.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Left">
            <TextBlock Style="{StaticResource H1}" Text="{loc:Loc Reports_Title}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{loc:Loc Reports_Subtitle}" />
        </StackPanel>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12,10" Margin="0,14,0,0">
            <WrapPanel Orientation="Horizontal">
                <ComboBox Style="{StaticResource AppComboBox}" Width="240" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding Reports}" SelectedItem="{Binding SelectedReport}" DisplayMemberPath="Title" />
                <!-- Company selection is global (header selector) -->

                <ComboBox Style="{StaticResource AppComboBox}" Width="120" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding Months}" SelectedValue="{Binding SelectedMonth}"
                          SelectedValuePath="Value" DisplayMemberPath="Label" IsEnabled="{Binding MonthEnabled}" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="90" Height="32" Margin="0,0,8,0"
                          ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Content="{loc:Loc Reports_Generate}" Command="{Binding GenerateCommand}" />
            </WrapPanel>
        </Border>

        <!-- Report header -->
        <StackPanel Grid.Row="2" Margin="2,14,0,0">
            <TextBlock Style="{StaticResource H2}" FontSize="15" Text="{Binding Title}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,3,0,0" Text="{Binding Subtitle}" />
        </StackPanel>

        <!-- Preview -->
        <DataGrid Grid.Row="3" Margin="0,12,0,0" ItemsSource="{Binding Preview}" AutoGenerateColumns="True"
                  IsReadOnly="True" CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  EnableRowVirtualization="True" EnableColumnVirtualization="True"
                  RowHeight="28" FontFamily="{StaticResource AppFont}" FontSize="12" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderHeight="34" />

        <!-- Actions -->
        <Grid Grid.Row="4" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Reports_ExportCsv}" Command="{Binding ExportCsvCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_ExportPdf}" Command="{Binding ExportPdfCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
