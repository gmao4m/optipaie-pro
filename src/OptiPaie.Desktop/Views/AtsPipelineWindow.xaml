<Window x:Class="OptiPaie.Desktop.Views.AtsPipelineWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Candidats" Height="540" Width="820"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Grid Margin="22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H2}" Text="{Binding PostingTitle}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" Text="{loc:Loc AtsPipe_Title}" />
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Content="{loc:Loc AtsPipe_AddCandidate}" Command="{Binding AddCommand}" />
        </Grid>

        <DataGrid Grid.Row="1" Margin="0,14,0,0" ItemsSource="{Binding Candidates}" SelectedItem="{Binding SelectedCandidate}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="{StaticResource AppFont}" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc AtsPipe_Candidate}" Binding="{Binding FullName}" Width="*" />
                <DataGridTextColumn Header="{loc:Loc Company_Phone}" Binding="{Binding Phone}" Width="120" />
                <DataGridTextColumn Header="{loc:Loc Company_Email}" Binding="{Binding Email}" Width="180" />
                <DataGridTextColumn Header="{loc:Loc Perf_Score}" Binding="{Binding RatingText}" Width="70" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc AtsPipe_ReceivedOn}" Binding="{Binding AppliedText}" Width="100" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc AtsPipe_Stage}" Binding="{Binding StageLabel}" Width="120" ElementStyle="{StaticResource CenterText}" />
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ComboBox Style="{StaticResource AppComboBox}" Width="140" Height="32" VerticalAlignment="Center"
                          ItemsSource="{Binding Stages}" SelectedItem="{Binding SelectedStage}" DisplayMemberPath="Label" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="6,0,0,0" Content="{loc:Loc AtsPipe_Move}" Command="{Binding MoveCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="6,0,0,0" Content="{loc:Loc AtsPipe_Reject}" Command="{Binding RejectCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="6,0,0,0" Content="{loc:Loc Common_Delete}" Command="{Binding DeleteCommand}" />
                <Button Style="{StaticResource AccentButton}" Height="32" Margin="6,0,0,0" Content="{loc:Loc AtsPipe_Hire}" Command="{Binding HireCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Height="32" Margin="6,0,0,0" Content="{loc:Loc Common_Close}" Command="{Binding CloseCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
