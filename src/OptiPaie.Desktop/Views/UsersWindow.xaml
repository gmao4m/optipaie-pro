<Window x:Class="OptiPaie.Desktop.Views.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OptiPaie PRO — Utilisateurs &amp; accès" Height="620" Width="820"
        WindowStartupLocation="CenterScreen" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H1}" Text="Utilisateurs &amp; accès" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0"
                       Text="Gérez les comptes locaux et activez la connexion pour protéger l'application." />
        </StackPanel>

        <!-- Login gate toggle -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="16,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox VerticalAlignment="Center" IsChecked="{Binding LoginEnabled}"
                          Content="Exiger une connexion au démarrage"
                          Foreground="{DynamicResource TextPrimary}" FontSize="13" FontWeight="SemiBold" />
                <TextBlock VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12"
                           Foreground="{DynamicResource TextMuted}"
                           Text="Nécessite au moins un administrateur actif. Effectif au prochain démarrage." />
            </StackPanel>
        </Border>

        <!-- Add form -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,14,0,0" Padding="16,14">
            <StackPanel>
                <TextBlock Text="Ajouter un utilisateur" FontSize="13.5" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,10" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource Caption}" Text="Nom d'utilisateur" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0"
                                 Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource Caption}" Text="Nom complet" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0"
                                 Text="{Binding NewFullName, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource Caption}" Text="Mot de passe initial" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0"
                                 Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="0,0,10,0">
                        <TextBlock Style="{StaticResource Caption}" Text="Rôle" />
                        <ComboBox Style="{StaticResource AppComboBox}" Margin="0,4,0,0"
                                  ItemsSource="{Binding Roles}" SelectedItem="{Binding NewRole}"
                                  DisplayMemberPath="Label" />
                    </StackPanel>
                    <Button Grid.Column="4" Style="{StaticResource PrimaryButton}" VerticalAlignment="Bottom"
                            Height="38" Content="Ajouter" Command="{Binding AddCommand}" />
                </Grid>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Style="{StaticResource Caption}" Text="Département (responsable) : " VerticalAlignment="Center" />
                    <TextBox Style="{StaticResource AppTextBox}" Width="240" Margin="6,0,0,0"
                             Text="{Binding NewDepartment, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- User list -->
        <DataGrid Grid.Row="3" Margin="0,14,0,0" ItemsSource="{Binding Users}" SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="Segoe UI" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nom d'utilisateur" Binding="{Binding Username}" Width="180" />
                <DataGridTextColumn Header="Nom complet" Binding="{Binding FullName}" Width="*" MinWidth="220" />
                <DataGridTextColumn Header="Rôle" Binding="{Binding RoleLabel}" Width="150" />
                <DataGridTextColumn Header="Département" Binding="{Binding Department}" Width="150" />
                <DataGridTextColumn Header="État" Binding="{Binding ActiveLabel}" Width="90" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Actions -->
        <Grid Grid.Row="4" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left"
                       Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Activer / Désactiver"
                        Command="{Binding ToggleActiveCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Supprimer"
                        Foreground="{DynamicResource Deduction}" Command="{Binding DeleteCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Fermer"
                        Command="{Binding CloseCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
