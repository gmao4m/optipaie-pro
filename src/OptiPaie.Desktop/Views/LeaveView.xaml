<UserControl x:Class="OptiPaie.Desktop.Views.LeaveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization">
    <UserControl.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="CenterText" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="Kpi" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,11" />
            <Setter Property="Margin" Value="0,0,12,0" />
        </Style>
    </UserControl.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title + selectors -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="{loc:Loc Dashboard_Leave}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{loc:Loc Leave_Subtitle}" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <!-- Company selection is global (header selector) -->

                <ComboBox Style="{StaticResource AppComboBox}" Width="90" Height="32" Margin="10,0,0,0" VerticalAlignment="Center"
                          ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
                <Button Style="{StaticResource PrimaryButton}" Height="32" Margin="10,0,0,0"
                        Content="{loc:Loc Leave_NewRequest}" Command="{Binding NewCommand}" />
            </StackPanel>
        </Grid>

        <!-- Balance of the selected employee -->
        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="{Binding BalanceCaption}" />
            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <Border Style="{StaticResource Kpi}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_DaysTaken}" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Text="{Binding TakenText}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_Remaining}" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Salary}" Text="{Binding RemainingText}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_Pending}" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Warning}" Text="{Binding PendingText}" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_Unpaid}" />
                        <TextBlock FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource Deduction}" Text="{Binding UnpaidText}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Requests -->
        <DataGrid x:Name="RequestsGrid" Grid.Row="2" Margin="0,18,0,0" ItemsSource="{Binding Requests}" SelectedItem="{Binding SelectedRequest}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="Segoe UI" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Payroll_Employee}" Binding="{Binding EmployeeName}" Width="*" />
                <DataGridTextColumn Header="{loc:Loc Common_Type}" Binding="{Binding TypeLabel}" Width="150" />
                <DataGridTextColumn Header="{loc:Loc Leave_Period}" Binding="{Binding Period}" Width="200" ElementStyle="{StaticResource CenterText}" />
                <DataGridTextColumn Header="{loc:Loc Leave_Days}" Binding="{Binding DaysText}" Width="70" ElementStyle="{StaticResource CenterText}" />
                <DataGridTemplateColumn Header="{loc:Loc Common_Status}" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusPill}">
                                <TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{loc:Loc Leave_Reason}" Binding="{Binding Reason}" Width="220" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource EmptyStateMessage}" Text="{loc:Loc Msg_NoData}"
                   Visibility="{Binding HasItems, ElementName=RequestsGrid, Converter={StaticResource InverseBoolToVis}}" />

        <!-- Actions -->
        <Grid Grid.Row="3" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Shell_Nav_Settings}" Command="{Binding SettingsCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Leave_TeamBalances}" Command="{Binding BalancesCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Edit}" Command="{Binding EditCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Leave_Reject}" Command="{Binding RejectCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Leave_Cancel}" Command="{Binding CancelCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Delete}" Command="{Binding DeleteCommand}" />
                <Button Style="{StaticResource AccentButton}" Margin="8,0,0,0" Content="{loc:Loc Leave_Approve}" Command="{Binding ApproveCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
