<Window x:Class="OptiPaie.Desktop.Views.AttendanceSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Paramètres de présence" Height="290" Width="430"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="{loc:Loc AttSet_Title}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="{loc:Loc AttSet_Hint}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc AttSet_StartTime}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding StandardStart, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc AttSet_StdHours}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding StandardHours, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc AttSet_LateTolerance}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding LateToleranceMinutes, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
