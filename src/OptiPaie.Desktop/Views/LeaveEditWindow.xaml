<Window x:Class="OptiPaie.Desktop.Views.LeaveEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{Binding Title}" Height="430" Width="460"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Payroll_Employee}" />
            <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                      ItemsSource="{Binding Employees}" SelectedItem="{Binding SelectedEmployee}"
                      IsEnabled="{Binding CanChooseEmployee}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock>
                            <Run Text="{Binding LastNameFr}" />
                            <Run Text="{Binding FirstNameFr}" />
                        </TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Leave_TypeField}" />
            <ComboBox Style="{StaticResource AppComboBox}" Height="32" Margin="0,4,0,0"
                      ItemsSource="{Binding Types}" SelectedItem="{Binding SelectedType}" DisplayMemberPath="Label" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Common_From}" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding StartDate}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Common_To}" />
                    <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding EndDate}" />
                </StackPanel>
            </Grid>

            <Border Background="{DynamicResource BrandSoft}" CornerRadius="8" Padding="10,7" Margin="0,12,0,0">
                <TextBlock FontSize="12.5" Foreground="{DynamicResource TextSecondary}" Text="{Binding DaysText}" />
            </Border>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Leave_Reason}" />
            <TextBox Style="{StaticResource AppTextBox}" Height="60" Margin="0,4,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                     Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
