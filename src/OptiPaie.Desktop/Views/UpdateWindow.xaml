<Window x:Class="OptiPaie.Desktop.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Mise à jour disponible"
        Height="500" Width="460" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        FontFamily="Segoe UI" Background="{DynamicResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource Brand}" Padding="24,22">
            <StackPanel>
                <TextBlock Text="{loc:Loc Upd_Title}" Foreground="{DynamicResource TextOnBrand}" FontSize="19" FontWeight="SemiBold" />
                <TextBlock Text="{Binding AppName}" Foreground="#D8EFE7" Margin="0,3,0,0" FontSize="13" />
            </StackPanel>
        </Border>

        <!-- Body -->
        <Grid Grid.Row="1" Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Versions -->
            <StackPanel Grid.Row="0" Orientation="Horizontal">
                <Border Background="{DynamicResource SurfaceMuted}" CornerRadius="8" Padding="12,8" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Upd_CurrentVersion}" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding CurrentVersion}" FontWeight="SemiBold" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
                <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TextMuted}" Data="{StaticResource IconArrowRight}" VerticalAlignment="Center" />
                <Border Background="{DynamicResource BrandSoft}" CornerRadius="8" Padding="12,8" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc Upd_NewVersion}" Style="{StaticResource Caption}" />
                        <TextBlock Text="{Binding LatestVersion}" FontWeight="SemiBold" Foreground="{DynamicResource Brand}" Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Mandatory banner -->
            <Border Grid.Row="1" Margin="0,14,0,0" CornerRadius="8" Padding="12,10" Background="#FDF0DC"
                    Visibility="{Binding Mandatory, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding MandatoryText}" TextWrapping="Wrap" Foreground="{DynamicResource Warning}" FontSize="12.5" />
            </Border>

            <!-- Release notes -->
            <TextBlock Grid.Row="1" Text="{loc:Loc Upd_ReleaseNotes}" Style="{StaticResource Caption}" Margin="0,16,0,6"
                       Visibility="{Binding Mandatory, Converter={StaticResource InverseBoolToVis}}" />
            <Border Grid.Row="2" Style="{StaticResource Card}" Background="{DynamicResource Surface}" Padding="14" Margin="0,42,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding ReleaseNotes}" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}" LineHeight="20" />
                </ScrollViewer>
            </Border>

            <!-- Progress + status -->
            <StackPanel Grid.Row="3" Margin="0,14,0,0">
                <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding Progress}"
                             Foreground="{DynamicResource Brand}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding StatusMessage}" Margin="0,8,0,0" TextWrapping="Wrap"
                           Visibility="{Binding StatusMessage, Converter={StaticResource EmptyToVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource Caption}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Failed}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource Deduction}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Grid>

        <!-- Footer buttons -->
        <Border Grid.Row="2" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{loc:Loc Upd_Later}" Style="{StaticResource SecondaryButton}" Height="40" Margin="0,0,10,0"
                        Command="{Binding LaterCommand}"
                        Visibility="{Binding CanPostpone, Converter={StaticResource BoolToVis}}" />
                <Button Content="{loc:Loc Upd_UpdateNow}" Style="{StaticResource PrimaryButton}" Height="40" MinWidth="190"
                        Command="{Binding UpdateCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
