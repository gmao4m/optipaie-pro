<Window x:Class="OptiPaie.Desktop.Views.GoalEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{Binding Title}" Height="470" Width="520"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{Binding Title}" />

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Payroll_Employee}" />
            <ComboBox Style="{StaticResource AppComboBox}" Height="38" Margin="0,4,0,0" IsEnabled="{Binding CanChooseEmployee}"
                      ItemsSource="{Binding Employees}" SelectedItem="{Binding Employee}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock><Run Text="{Binding LastNameFr}" /><Run Text=" " /><Run Text="{Binding FirstNameFr}" /></TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc GoalEdit_Title}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding GoalTitle, UpdateSourceTrigger=PropertyChanged}" />

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc GoalEdit_Target}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding TargetMetric, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Contract_Expiry}" />
                    <DatePicker Height="34" Margin="0,4,0,0" SelectedDate="{Binding DueDate}" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource Caption}" Margin="0,14,0,0">
                <Run Text="{loc:Loc GoalEdit_ProgressLabel}" /><Run Text="{Binding Progress}" /><Run Text="{loc:Loc Common_PercentSuffix}" />
            </TextBlock>
            <Slider Margin="0,6,0,0" Minimum="0" Maximum="100" TickFrequency="5" IsSnapToTickEnabled="True" Value="{Binding ProgressValue, Mode=TwoWay}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Common_Status}" />
            <ComboBox Style="{StaticResource AppComboBox}" Height="38" Margin="0,4,0,0" ItemsSource="{Binding Statuses}" SelectedItem="{Binding Status}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
