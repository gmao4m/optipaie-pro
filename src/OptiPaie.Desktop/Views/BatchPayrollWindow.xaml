<Window x:Class="OptiPaie.Desktop.Views.BatchPayrollWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{loc:Loc Batch_Title}" Height="640" Width="780"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <Style x:Key="GridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>
        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="ChipCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="11.5" />
        </Style>
        <Style x:Key="ChipValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title + period -->
        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="{loc:Loc Batch_Title}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0">
                    <Run Text="{loc:Loc Batch_Subtitle}" /><Run Text="  ·  " /><Run Text="{Binding CompanyName, Mode=OneWay}" />
                </TextBlock>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <TextBlock Text="{loc:Loc Payroll_Month}" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,6,0" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="120" Height="32" ItemsSource="{Binding Months}"
                          SelectedValue="{Binding SelectedMonth}" SelectedValuePath="Value" DisplayMemberPath="Label" />
                <TextBlock Text="{loc:Loc Payroll_Year}" VerticalAlignment="Center" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="14,0,6,0" />
                <ComboBox Style="{StaticResource AppComboBox}" Width="80" Height="32" ItemsSource="{Binding Years}" SelectedItem="{Binding SelectedYear}" />
            </StackPanel>
        </Grid>

        <!-- Pre-run summary chips -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0"
                    Visibility="{Binding HasPlan, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Chip}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ChipCaption}" Text="{loc:Loc Batch_Total}" />
                    <TextBlock Style="{StaticResource ChipValue}" Text="{Binding TotalText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Chip}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ChipCaption}" Text="{loc:Loc Batch_ReadyCount}" />
                    <TextBlock Style="{StaticResource ChipValue}" Foreground="{DynamicResource StatusSuccess}" Text="{Binding ReadyText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Chip}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ChipCaption}" Text="{loc:Loc Batch_Blocked}" />
                    <TextBlock Style="{StaticResource ChipValue}" Foreground="{DynamicResource StatusDanger}" Text="{Binding BlockedText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Chip}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ChipCaption}" Text="{loc:Loc Batch_Warning}" />
                    <TextBlock Style="{StaticResource ChipValue}" Foreground="{DynamicResource StatusPending}" Text="{Binding WarningsText}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Already-archived banner -->
        <Border Grid.Row="2" Margin="0,12,0,0" Background="{DynamicResource StatusDangerSoft}" CornerRadius="8" Padding="12,8"
                Visibility="{Binding AlreadyArchived, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{loc:Loc Batch_AlreadyArchived}" Foreground="{DynamicResource StatusDanger}" FontSize="12.5" TextWrapping="Wrap" />
        </Border>

        <!-- Results summary chips -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,12,0,0"
                    Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}">
            <Border Style="{StaticResource Chip}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ChipCaption}" Text="{loc:Loc Batch_Succeeded}" />
                    <TextBlock Style="{StaticResource ChipValue}" Foreground="{DynamicResource StatusSuccess}" Text="{Binding SucceededText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Chip}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ChipCaption}" Text="{loc:Loc Batch_Skipped}" />
                    <TextBlock Style="{StaticResource ChipValue}" Foreground="{DynamicResource StatusNeutral}" Text="{Binding SkippedText}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Chip}">
                <StackPanel>
                    <TextBlock Style="{StaticResource ChipCaption}" Text="{loc:Loc Batch_Failed}" />
                    <TextBlock Style="{StaticResource ChipValue}" Foreground="{DynamicResource StatusDanger}" Text="{Binding FailedText}" />
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Pre-run plan grid (hidden once results arrive) -->
        <DataGrid Grid.Row="4" Margin="0,14,0,0" ItemsSource="{Binding PlanRows}"
                  Visibility="{Binding HasResults, Converter={StaticResource InverseBoolToVis}}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="{StaticResource AppFont}" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Payroll_Employee}" Binding="{Binding EmployeeName}" Width="*" />
                <DataGridTemplateColumn Header="{loc:Loc Common_Status}" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusPill}">
                                <TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{loc:Loc Batch_Detail}" Binding="{Binding Reason}" Width="2*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Results grid (with drill-in on double click) -->
        <DataGrid Grid.Row="4" Margin="0,14,0,0" ItemsSource="{Binding ResultRows}" SelectedItem="{Binding SelectedResult}"
                  Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="All"
                  RowHeight="32" FontFamily="{StaticResource AppFont}" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}" VerticalGridLinesBrush="{DynamicResource Border}"
                  ColumnHeaderStyle="{StaticResource GridHeader}">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding OpenSelectedCommand}" />
            </DataGrid.InputBindings>
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Payroll_Employee}" Binding="{Binding EmployeeName}" Width="*" />
                <DataGridTemplateColumn Header="{loc:Loc Common_Status}" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource StatusPill}">
                                <TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" />
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{loc:Loc Payroll_NetToPay}" Binding="{Binding NetText}" Width="130">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                            <Setter Property="TextAlignment" Value="Right" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="Margin" Value="0,0,8,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="{loc:Loc Batch_Detail}" Binding="{Binding Message}" Width="1.4*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Progress -->
        <StackPanel Grid.Row="5" Margin="0,12,0,0" Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}">
            <TextBlock Style="{StaticResource Caption}" Text="{Binding StatusMessage}" />
            <Grid Margin="0,6,0,0">
                <ProgressBar Height="10" Minimum="0" Maximum="{Binding ProgressTotal, Mode=OneWay}" Value="{Binding ProgressDone, Mode=OneWay}"
                             Background="{DynamicResource SurfaceMuted}" Foreground="{DynamicResource Accent}" BorderThickness="0" />
                <TextBlock Text="{Binding ProgressText}" FontFamily="{StaticResource MonoFont}" FontSize="10.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" />
            </Grid>
        </StackPanel>

        <!-- Actions -->
        <Grid Grid.Row="6" Margin="0,16,0,0">
            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Center" HorizontalAlignment="Left" Text="{Binding StatusMessage}"
                       Visibility="{Binding IsRunning, Converter={StaticResource InverseBoolToVis}}" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Batch_Recheck}" Command="{Binding CheckCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Batch_Open}" Command="{Binding OpenSelectedCommand}"
                        Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Batch_ExportAll}" Command="{Binding ExportAllCommand}"
                        Visibility="{Binding HasResults, Converter={StaticResource BoolToVis}}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Batch_Run}" Command="{Binding RunCommand}"
                        Visibility="{Binding HasResults, Converter={StaticResource InverseBoolToVis}}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Close}" Click="Close_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
