<Window x:Class="OptiPaie.Desktop.Views.ContractTerminateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Résilier le contrat" Height="290" Width="420"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="Résilier le contrat" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="La date de sortie sera enregistrée sur la fiche de l'employé." />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="Date d'effet" />
            <DatePicker Height="32" Margin="0,4,0,0" SelectedDate="{Binding EffectiveDate}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="Motif" />
            <TextBox Style="{StaticResource AppTextBox}" Height="56" Margin="0,4,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                     Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Résilier" Command="{Binding ConfirmCommand}" />
        </StackPanel>
    </Grid>
</Window>
