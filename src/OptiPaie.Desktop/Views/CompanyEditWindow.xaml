<Window x:Class="OptiPaie.Desktop.Views.CompanyEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{Binding Title}" Width="640" Height="780"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        FontFamily="Segoe UI" Background="{DynamicResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1" Padding="24,18">
            <TextBlock Style="{StaticResource H2}" Text="{Binding Title}" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel>
                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Company_GroupIdentity}" />
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_NameFr}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.NameFr, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_NameAr}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.NameAr}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_LegalForm}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.LegalForm}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Company_GroupContact}" />
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_AddressFr}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.AddressFr}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_AddressAr}" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.AddressAr}" />
                        </StackPanel>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_Phone}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Phone}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_Email}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Email}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Company_GroupLegal}" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_Nif}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Nif}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_Nis}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Nis}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_Rc}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Rc}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_ArticleImposition}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.ArticleImposition}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_CnasEmployerNumber}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.CnasEmployerNumber}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CACOBATPH" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Cacobatph}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Cacobatph_Section}" />
                        <CheckBox IsChecked="{Binding BtphSector}" Content="{loc:Loc Cacobatph_SectorToggle}"
                                  Foreground="{DynamicResource TextPrimary}" FontSize="13" VerticalContentAlignment="Center" />
                        <CheckBox Margin="0,10,0,0" IsChecked="{Binding CacobatphEnabled}" IsEnabled="{Binding CanEnableCacobatph}"
                                  Content="{loc:Loc Cacobatph_EnableToggle}" FontSize="13" FontWeight="SemiBold"
                                  Foreground="{DynamicResource TextPrimary}" VerticalContentAlignment="Center" />
                        <TextBlock Margin="24,6,0,0" TextWrapping="Wrap" FontSize="11.5"
                                   Foreground="{DynamicResource TextMuted}" Text="{loc:Loc Cacobatph_Hint}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Company_Bank}" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Company_Bank}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Bank}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="{loc:Loc Cmp_AccountRib}" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.BankAccount}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Company_Logo}" />
                        <StackPanel Orientation="Horizontal">
                            <Border Width="90" Height="90" CornerRadius="12" Background="{DynamicResource SurfaceMuted}" BorderBrush="{DynamicResource Border}" BorderThickness="1" ClipToBounds="True">
                                <Image Source="{Binding Logo, Converter={StaticResource BytesToImage}}" Stretch="Uniform" Margin="8" />
                            </Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Company_UploadLogo}" Command="{Binding PickLogoCommand}" HorizontalAlignment="Left" />
                                <Button Style="{StaticResource SecondaryButton}" Margin="0,8,0,0" Content="{loc:Loc Company_ClearLogo}" Command="{Binding ClearLogoCommand}" HorizontalAlignment="Left" Foreground="{DynamicResource Deduction}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
