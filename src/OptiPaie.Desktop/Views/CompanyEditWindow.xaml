<Window x:Class="OptiPaie.Desktop.Views.CompanyEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}" Width="640" Height="780"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        FontFamily="Segoe UI" Background="{StaticResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

    <Window.Resources>
        <Style x:Key="FieldLabel" TargetType="TextBlock" BasedOn="{StaticResource Caption}">
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1" Padding="24,18">
            <TextBlock Style="{StaticResource H2}" Text="{Binding Title}" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel>
                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Identité" />
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Nom (FR)" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.NameFr, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Nom (AR)" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.NameAr}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Forme juridique" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.LegalForm}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Coordonnées" />
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Adresse (FR)" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.AddressFr}" />
                        </StackPanel>
                        <StackPanel Margin="0,0,0,14">
                            <TextBlock Style="{StaticResource FieldLabel}" Text="Adresse (AR)" />
                            <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.AddressAr}" />
                        </StackPanel>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Téléphone" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Phone}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="E-mail" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Email}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Identifiants légaux" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="NIF" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Nif}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="NIS" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Nis}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="RC" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Rc}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,14">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Article d'imposition" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.ArticleImposition}" />
                            </StackPanel>
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="N° CNAS employeur" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.CnasEmployerNumber}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="CACOBATPH" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Cacobatph}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Banque" />
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,8,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Banque" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.Bank}" />
                            </StackPanel>
                            <StackPanel Margin="8,0,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="Compte / RIB" />
                                <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Company.BankAccount}" />
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Padding="20">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Logo" />
                        <StackPanel Orientation="Horizontal">
                            <Border Width="90" Height="90" CornerRadius="12" Background="{StaticResource SurfaceMuted}" BorderBrush="{StaticResource Border}" BorderThickness="1" ClipToBounds="True">
                                <Image Source="{Binding Logo, Converter={StaticResource BytesToImage}}" Stretch="Uniform" Margin="8" />
                            </Border>
                            <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                <Button Style="{StaticResource SecondaryButton}" Content="Choisir un logo" Command="{Binding PickLogoCommand}" HorizontalAlignment="Left" />
                                <Button Style="{StaticResource SecondaryButton}" Margin="0,8,0,0" Content="Retirer" Command="{Binding ClearLogoCommand}" HorizontalAlignment="Left" Foreground="{StaticResource Deduction}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{StaticResource Surface}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Style="{StaticResource SecondaryButton}" Content="Annuler" Command="{Binding CancelCommand}" />
                <Button Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Content="Enregistrer" Command="{Binding SaveCommand}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
