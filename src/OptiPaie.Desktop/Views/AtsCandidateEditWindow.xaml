<Window x:Class="OptiPaie.Desktop.Views.AtsCandidateEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Nouveau candidat" Height="440" Width="450"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{loc:Loc AtsEdit_NewCandidate}" />

        <StackPanel Grid.Row="1" Margin="0,16,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_LastName}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_FirstName}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Company_Phone}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Company_Email}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Common_Source}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc AtsEdit_Rating}" />
                    <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Rating, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Grid>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Common_Notes}" />
            <TextBox Style="{StaticResource AppTextBox}" Height="64" Margin="0,4,0,0"
                     AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"
                     Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
