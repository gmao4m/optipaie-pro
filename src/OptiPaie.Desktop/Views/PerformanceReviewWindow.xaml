<Window x:Class="OptiPaie.Desktop.Views.PerformanceReviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{Binding Title}" Height="740" Width="800"
        MinHeight="560" MinWidth="680"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header band: employee + live overall score -->
        <Border Grid.Row="0" Background="{DynamicResource Brand}" Padding="24,18">
            <Grid>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="{Binding EmployeeName}" FontFamily="{StaticResource MonoFont}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextOnBrand}" />
                    <TextBlock Text="{Binding EmployeeMeta}" FontSize="12.5" Margin="0,3,0,0" Foreground="#B9C2D6" />
                    <TextBlock Margin="0,2,0,0" FontSize="12" Foreground="#B9C2D6">
                        <Run Text="{loc:Loc PerfReview_PeriodLabel}" />
                        <Run Text="{Binding PeriodLabel}" FontWeight="SemiBold" />
                    </TextBlock>
                </StackPanel>
                <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#22FFFFFF" CornerRadius="12" Padding="20,10">
                    <StackPanel>
                        <TextBlock Text="{loc:Loc PerfReview_GlobalScore}" FontSize="11" Foreground="#B9C2D6" HorizontalAlignment="Right" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                            <TextBlock Text="{Binding OverallText}" FontSize="30" FontWeight="Bold" Foreground="{DynamicResource TextOnBrand}" />
                        </StackPanel>
                        <Border HorizontalAlignment="Right" Margin="0,4,0,0" CornerRadius="7" Padding="10,3" Background="{Binding OverallBrush}">
                            <TextBlock Text="{Binding RatingText}" FontSize="12" FontWeight="SemiBold" Foreground="White" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,18">
            <StackPanel>
                <!-- Reviewer + attendance -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="1.4*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Perf_Reviewer}" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" IsEnabled="{Binding IsEditable}"
                                 Text="{Binding Reviewer, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <Border Grid.Column="2" VerticalAlignment="Bottom" Height="38" Background="{DynamicResource AccentSoft}" CornerRadius="8" Padding="12,0"
                            Visibility="{Binding HasAttendance, Converter={StaticResource BoolVis}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Width="15" Height="15" Stretch="Uniform" Fill="{DynamicResource Accent}" Data="{StaticResource IconClock}" VerticalAlignment="Center" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecondary}" Text="{Binding AttendanceText}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Performance → Training: suggestion for the weakest criterion -->
                <Border Margin="0,16,0,0" Background="{DynamicResource AccentSoft}" CornerRadius="8" Padding="12,10"
                        Visibility="{Binding HasSuggestion, Converter={StaticResource BoolVis}}">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource Accent}" Data="{StaticResource IconSchool}" VerticalAlignment="Top" Margin="0,1,0,0" />
                        <TextBlock Margin="10,0,0,0" FontSize="12.5" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Text="{Binding SuggestionText}" />
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,20,0,8" Style="{StaticResource Caption}" Text="{loc:Loc PerfReview_CriteriaHeader}" FontWeight="SemiBold" />

                <!-- Criterion cards -->
                <ItemsControl ItemsSource="{Binding Criteria}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource Card}" Padding="16,14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="300" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Label}" FontSize="14.5" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding ShareText}" FontSize="11.5" Margin="0,3,0,10" Foreground="{DynamicResource TextMuted}" />
                                        <TextBox Style="{StaticResource AppTextBox}" Height="34" MinWidth="200"
                                                 IsEnabled="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                 VerticalContentAlignment="Center"
                                                 Text="{Binding Comment, UpdateSourceTrigger=PropertyChanged}"
                                                 ToolTip="Commentaire sur ce critère" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding ScoreText}" HorizontalAlignment="Right" FontSize="26" FontWeight="Bold"
                                                   FontFamily="{StaticResource MonoFont}" Foreground="{Binding ScoreBrush}" />
                                        <Slider Margin="0,6,0,0" Minimum="0" Maximum="{Binding ScaleMaxDouble}"
                                                Value="{Binding SliderValue, Mode=TwoWay}" TickFrequency="1" IsSnapToTickEnabled="True"
                                                IsEnabled="{Binding DataContext.IsEditable, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Observations -->
                <TextBlock Margin="0,10,0,8" Style="{StaticResource Caption}" Text="{loc:Loc PerfReview_ObsHeader}" FontWeight="SemiBold" />
                <TextBox Style="{StaticResource AppTextBox}" Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalContentAlignment="Top" IsEnabled="{Binding IsEditable}"
                         Text="{Binding Comments, UpdateSourceTrigger=PropertyChanged}" />

                <!-- Self-assessment -->
                <TextBlock Margin="0,18,0,8" Style="{StaticResource Caption}" Text="{loc:Loc PerfReview_SelfHeader}" FontWeight="SemiBold" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc PerfReview_EmpScore}" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" IsEnabled="{Binding IsEditable}"
                                 Text="{Binding SelfScoreText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc PerfReview_EmpComment}" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" IsEnabled="{Binding IsEditable}"
                                 Text="{Binding SelfComments, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Border}" BorderThickness="0,1,0,0" Padding="24,12">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_ExportPdf}" Command="{Binding PdfCommand}" />
                    <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Ats_Reopen}" Command="{Binding ReopenCommand}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Close}" Command="{Binding CancelCommand}" />
                    <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}"
                            IsEnabled="{Binding IsEditable}" />
                    <Button Style="{StaticResource AccentButton}" Margin="8,0,0,0" Content="{loc:Loc PerfReview_Finalize}" Command="{Binding CompleteCommand}"
                            IsEnabled="{Binding IsEditable}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
