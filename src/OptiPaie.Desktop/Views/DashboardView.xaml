<UserControl x:Class="OptiPaie.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="Kpi" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="16,13" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Width" Value="182" />
        </Style>
        <Style x:Key="KpiValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <StackPanel HorizontalAlignment="Left">
                    <TextBlock Style="{StaticResource H1}" Text="{Binding Greeting}" />
                    <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{Binding DateLabel}" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource SecondaryButton}" Content="Actualiser" Command="{Binding RefreshCommand}" />
                    <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="Établir une paie" Command="{Binding NewPayrollCommand}" />
                </StackPanel>
            </Grid>

            <!-- KPI cards -->
            <WrapPanel Grid.Row="1" Orientation="Horizontal" Margin="0,18,0,0">
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Effectif" />
                        <TextBlock Style="{StaticResource KpiValue}" Text="{Binding Employees}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Présents aujourd'hui" />
                        <TextBlock Style="{StaticResource KpiValue}" Foreground="{DynamicResource Salary}" Text="{Binding PresentToday}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="En congé" />
                        <TextBlock Style="{StaticResource KpiValue}" Foreground="{DynamicResource Employer}" Text="{Binding OnLeave}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="En mission" />
                        <TextBlock Style="{StaticResource KpiValue}" Foreground="{DynamicResource Employer}" Text="{Binding OnMission}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Contrats en vigueur" />
                        <TextBlock Style="{StaticResource KpiValue}" Text="{Binding ActiveContracts}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Contrats à échéance" />
                        <TextBlock Style="{StaticResource KpiValue}" Foreground="{DynamicResource Warning}" Text="{Binding Expiring}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Congés en attente" />
                        <TextBlock Style="{StaticResource KpiValue}" Foreground="{DynamicResource Warning}" Text="{Binding PendingLeave}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Encours prêts (DA)" />
                        <TextBlock Style="{StaticResource KpiValue}" Foreground="{DynamicResource Deduction}" Text="{Binding LoanOutstanding}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Postes ouverts" />
                        <TextBlock Style="{StaticResource KpiValue}" Text="{Binding OpenPostings}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Candidats" />
                        <TextBlock Style="{StaticResource KpiValue}" Text="{Binding Candidates}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Matériel attribué" />
                        <TextBlock Style="{StaticResource KpiValue}" Text="{Binding AssetsAssigned}" /></StackPanel>
                </Border>
                <Border Style="{StaticResource Kpi}">
                    <StackPanel><TextBlock Style="{StaticResource Caption}" Text="Formations à venir" />
                        <TextBlock Style="{StaticResource KpiValue}" Text="{Binding TrainingUpcoming}" /></StackPanel>
                </Border>
            </WrapPanel>

            <!-- Approvals + deadlines -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Approvals queue -->
                <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource H2}" FontSize="15" Text="{Binding ApprovalsHeader}" Margin="16,14,16,8" />
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Approvals}" Margin="8,0,8,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch" Cursor="Hand" BorderThickness="0" Background="Transparent"
                                            Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ModuleKey}">
                                        <Border Background="{DynamicResource SurfaceMuted}" CornerRadius="8" Padding="12,9" Margin="0,2">
                                            <Grid>
                                                <StackPanel HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12.5" />
                                                    <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondary}" FontSize="11.5" Margin="0,2,0,0" />
                                                </StackPanel>
                                                <TextBlock Text="Traiter →" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource Brand}" FontWeight="SemiBold" FontSize="12" />
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Grid.Row="1" Text="Rien à traiter — tout est à jour." Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20"
                                   Visibility="{Binding HasApprovals, Converter={StaticResource InverseBoolToVis}}" />
                    </Grid>
                </Border>

                <!-- Deadlines -->
                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource H2}" FontSize="15" Text="{Binding DeadlinesHeader}" Margin="16,14,16,8" />
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding Deadlines}" Margin="8,0,8,10">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button HorizontalContentAlignment="Stretch" Cursor="Hand" BorderThickness="0" Background="Transparent"
                                            Command="{Binding DataContext.OpenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding ModuleKey}">
                                        <Border Background="{DynamicResource SurfaceMuted}" CornerRadius="8" Padding="12,9" Margin="0,2">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="12.5" />
                                                <TextBlock Text="{Binding Detail}" Foreground="{DynamicResource TextSecondary}" FontSize="11.5" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Grid.Row="1" Text="Aucune échéance dans les 30 jours." Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,20"
                                   Visibility="{Binding HasDeadlines, Converter={StaticResource InverseBoolToVis}}" />
                    </Grid>
                </Border>
            </Grid>

            <!-- Activity journal (audit trail) -->
            <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" FontSize="15" Text="Journal d'activité" Margin="16,14,16,8" />
                    <ItemsControl ItemsSource="{Binding RecentActivity}" Margin="14,0,14,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <TextBlock Text="{Binding Text}" FontSize="12.5" HorizontalAlignment="Left" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding Detail}" FontSize="11.5" Foreground="{DynamicResource TextSecondary}"
                                               HorizontalAlignment="Right" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Aucune activité enregistrée pour l'instant." Foreground="{DynamicResource TextMuted}"
                               Margin="16,0,0,14" Visibility="{Binding HasActivity, Converter={StaticResource InverseBoolToVis}}" />
                </StackPanel>
            </Border>

            <!-- Quick actions -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,16,0,0">
                <Button Style="{StaticResource SecondaryButton}" Content="Nouvel employé" Command="{Binding NewEmployeeCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Matrice de présence" Command="{Binding AttendanceCommand}" />
                <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="Congés" Command="{Binding LeaveCommand}" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
