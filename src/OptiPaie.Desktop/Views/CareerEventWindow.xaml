<Window x:Class="OptiPaie.Desktop.Views.CareerEventWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{Binding Title}" Height="440" Width="500"
        WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis" />
    </Window.Resources>
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="{Binding Title}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="{Binding EmployeeName}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <!-- Promotion fields -->
            <StackPanel Visibility="{Binding IsPromotion, Converter={StaticResource BoolVis}}">
                <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Career_OldPosition}" />
                <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding OldPosition, UpdateSourceTrigger=PropertyChanged}" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Career_NewPosition}" />
                <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding NewPosition, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- Reward fields -->
            <StackPanel Visibility="{Binding IsReward, Converter={StaticResource BoolVis}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Loan_Amount}" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Employee_Category}" />
                        <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>
            </StackPanel>

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Recent_Date}" />
            <DatePicker Height="34" Margin="0,4,0,0" SelectedDate="{Binding EventDate}" HorizontalAlignment="Left" Width="200" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc Leave_Reason}" />
            <TextBox Style="{StaticResource AppTextBox}" Height="60" Margin="0,4,0,0" AcceptsReturn="True" TextWrapping="Wrap"
                     VerticalContentAlignment="Top" Text="{Binding Reason, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
