<Window x:Class="OptiPaie.Desktop.Views.EmployeeProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="{loc:Loc Profile_Title}" Height="820" Width="920"
        ResizeMode="CanResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Window.Resources>
        <!-- Section card -->
        <Style x:Key="Section" TargetType="Border" BasedOn="{StaticResource Card}">
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
        <Style x:Key="SectionTitle" TargetType="TextBlock" BasedOn="{StaticResource H2}">
            <Setter Property="FontSize" Value="15" />
        </Style>
        <Style x:Key="Tile" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceMuted}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,10,0" />
        </Style>
        <Style x:Key="TileValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="19" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
        <Style x:Key="Link" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="FontSize" Value="11.5" />
        </Style>
        <Style x:Key="RowText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
        <Style x:Key="RowNum" TargetType="TextBlock" BasedOn="{StaticResource RowText}">
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="TextAlignment" Value="Right" />
        </Style>
        <Style x:Key="RowMuted" TargetType="TextBlock" BasedOn="{StaticResource RowText}">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
        </Style>
        <Style x:Key="Empty" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Margin" Value="0,4,0,0" />
        </Style>
        <!-- CDI/CDD badge bound to the header VM (ContractTypeKind) -->
        <Style x:Key="HdrTypePill" TargetType="Border" BasedOn="{StaticResource StatusPill}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ContractTypeKind}" Value="accent"><Setter Property="Background" Value="{DynamicResource Accent}" /></DataTrigger>
                <DataTrigger Binding="{Binding ContractTypeKind}" Value="pending"><Setter Property="Background" Value="{DynamicResource StatusPending}" /></DataTrigger>
                <DataTrigger Binding="{Binding ContractTypeKind}" Value="neutral"><Setter Property="Background" Value="{DynamicResource StatusNeutral}" /></DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- CDI/CDD badge bound to each contract row (TypeKind) -->
        <Style x:Key="RowTypePill" TargetType="Border">
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Padding" Value="9,2" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource StatusNeutral}" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding TypeKind}" Value="accent"><Setter Property="Background" Value="{DynamicResource Accent}" /></DataTrigger>
                <DataTrigger Binding="{Binding TypeKind}" Value="pending"><Setter Property="Background" Value="{DynamicResource StatusPending}" /></DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="20,16">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Border Width="58" Height="58" CornerRadius="29" Background="{DynamicResource BrandSoft}" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Initials}" FontFamily="{StaticResource AppFont}" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrandText}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding FullName}" Style="{StaticResource H1}" VerticalAlignment="Center" />
                            <Border Style="{StaticResource HdrTypePill}" Margin="12,0,0,0">
                                <TextBlock Style="{StaticResource PillText}" Text="{Binding ContractTypeLabel}" />
                            </Border>
                            <Border Style="{StaticResource StatusPill}" Margin="6,0,0,0">
                                <TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Margin="0,4,0,0" FontSize="13" Foreground="{DynamicResource TextSecondary}">
                            <Run Text="{Binding Poste, Mode=OneWay}" /><Run Text="  ·  " /><Run Text="{Binding Department, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Margin="0,3,0,0" Style="{StaticResource Caption}">
                            <Run Text="Matricule " /><Run Text="{Binding Matricule, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" /><Run Text="   ·   Embauché le " /><Run Text="{Binding HireDateText, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                    <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Edit}" Command="{Binding EditCommand}" />
                    <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Profile_ExportDossier}" Command="{Binding ExportCommand}" />
                    <Button Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Close}" Click="Close_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,14,0,0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel>

                <!-- Attendance + Leave balance row -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Section}" Margin="0,0,0,0">
                        <StackPanel>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoAttendanceCommand}" />
                                <TextBlock Style="{StaticResource SectionTitle}">
                                    <Run Text="{loc:Loc Shell_Nav_Attendance}" /><Run Text="  ·  " /><Run Text="{Binding AttendancePeriod, Mode=OneWay}" FontSize="12" Foreground="{DynamicResource TextMuted}" />
                                </TextBlock>
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Border Style="{StaticResource Tile}"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Att_Present}" /><TextBlock Style="{StaticResource TileValue}" Foreground="{DynamicResource StatusSuccess}" Text="{Binding PresentText}" /></StackPanel></Border>
                                <Border Style="{StaticResource Tile}"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Att_Absent}" /><TextBlock Style="{StaticResource TileValue}" Foreground="{DynamicResource StatusDanger}" Text="{Binding AbsentText}" /></StackPanel></Border>
                                <Border Style="{StaticResource Tile}"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Att_Late}" /><TextBlock Style="{StaticResource TileValue}" Foreground="{DynamicResource StatusPending}" Text="{Binding LateText}" /></StackPanel></Border>
                                <Border Style="{StaticResource Tile}" Margin="0"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Dashboard_Leave}" /><TextBlock Style="{StaticResource TileValue}" Foreground="{DynamicResource Employer}" Text="{Binding OnLeaveText}" /></StackPanel></Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Section}" Margin="0,0,0,0">
                        <StackPanel>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoLeaveCommand}" />
                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Profile_LeaveBalance}" />
                            </DockPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                <Border Style="{StaticResource Tile}"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_Entitlement}" /><TextBlock Style="{StaticResource TileValue}" Text="{Binding LeaveEntitlementText}" /></StackPanel></Border>
                                <Border Style="{StaticResource Tile}"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_DaysTaken}" /><TextBlock Style="{StaticResource TileValue}" Text="{Binding LeaveTakenText}" /></StackPanel></Border>
                                <Border Style="{StaticResource Tile}"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_Remaining}" /><TextBlock Style="{StaticResource TileValue}" Foreground="{DynamicResource StatusSuccess}" Text="{Binding LeaveRemainingText}" /></StackPanel></Border>
                                <Border Style="{StaticResource Tile}" Margin="0"><StackPanel><TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Leave_Pending}" /><TextBlock Style="{StaticResource TileValue}" Foreground="{DynamicResource StatusPending}" Text="{Binding LeavePendingText}" /></StackPanel></Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Contracts -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoContractsCommand}" />
                            <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Contract_Title}" />
                        </DockPanel>
                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Contracts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,7" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="120" /><ColumnDefinition Width="180" /><ColumnDefinition Width="110" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Style="{StaticResource RowTypePill}"><TextBlock Style="{StaticResource PillText}" Text="{Binding TypeLabel}" /></Border>
                                            <TextBlock Grid.Column="1" Style="{StaticResource RowText}" Text="{Binding Position}" FontWeight="{Binding IsCurrent, Converter={StaticResource BoolToWeight}}" />
                                            <TextBlock Grid.Column="2" Style="{StaticResource RowNum}" Text="{Binding SalaryText}" />
                                            <TextBlock Grid.Column="3" Style="{StaticResource RowMuted}" Text="{Binding PeriodText}" FontFamily="{StaticResource MonoFont}" TextAlignment="Center" />
                                            <Border Grid.Column="4" Style="{StaticResource StatusPill}"><TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" /></Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Style="{StaticResource Empty}" Text="{loc:Loc Msg_NoData}" Visibility="{Binding HasContracts, Converter={StaticResource InverseBoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- Payroll -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoPayrollCommand}" />
                            <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Profile_Payroll}" />
                        </DockPanel>
                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Payslips}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,7" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="160" /><ColumnDefinition Width="120" /></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource RowText}" Text="{Binding PeriodText}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource RowNum}" Text="{Binding NetText}" Margin="0,0,16,0" />
                                            <Button Grid.Column="2" Style="{StaticResource Link}" HorizontalAlignment="Right" Content="{loc:Loc Profile_OpenPayslip}"
                                                    Command="{Binding DataContext.ReopenPayslipCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Style="{StaticResource Empty}" Text="{loc:Loc Msg_NoData}" Visibility="{Binding HasPayslips, Converter={StaticResource InverseBoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- Loans + Assets -->
                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Section}">
                        <StackPanel>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoLoansCommand}" />
                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Loan_Title}" />
                            </DockPanel>
                            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Loans}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,7" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Style="{StaticResource RowNum}" HorizontalAlignment="Left" TextAlignment="Left" Text="{Binding OutstandingText}" />
                                                    <TextBlock Style="{StaticResource RowMuted}" FontSize="11">
                                                        <Run Text="Mensualité " /><Run Text="{Binding InstallmentText, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" /><Run Text="  ·  " /><Run Text="{Binding RemainingText, Mode=OneWay}" FontFamily="{StaticResource MonoFont}" />
                                                    </TextBlock>
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource StatusPill}"><TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" /></Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Style="{StaticResource Empty}" Text="{loc:Loc Msg_NoData}" Visibility="{Binding HasLoans, Converter={StaticResource InverseBoolToVis}}" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Section}">
                        <StackPanel>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoAssetsCommand}" />
                                <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Asset_Title}" />
                            </DockPanel>
                            <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Assets}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="0,7" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="170" /><ColumnDefinition Width="80" /></Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Style="{StaticResource RowText}" Text="{Binding AssetName}" />
                                                <TextBlock Grid.Column="1" Style="{StaticResource RowMuted}" FontFamily="{StaticResource MonoFont}" FontSize="11.5">
                                                    <Run Text="{Binding AssignedText, Mode=OneWay}" /><Run Text=" → " /><Run Text="{Binding ReturnedText, Mode=OneWay}" />
                                                </TextBlock>
                                                <Border Grid.Column="2" Style="{StaticResource StatusPill}"><TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" /></Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Style="{StaticResource Empty}" Text="{loc:Loc Msg_NoData}" Visibility="{Binding HasAssets, Converter={StaticResource InverseBoolToVis}}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Training -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoTrainingCommand}" />
                            <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Training_Title}" />
                        </DockPanel>
                        <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding Training}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,7" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="150" /><ColumnDefinition Width="95" /><ColumnDefinition Width="110" /></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource RowText}" Text="{Binding Title}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource RowMuted}" Text="{Binding Provider}" />
                                            <TextBlock Grid.Column="2" Style="{StaticResource RowMuted}" FontFamily="{StaticResource MonoFont}" TextAlignment="Center" Text="{Binding DateText}" />
                                            <Border Grid.Column="3" Style="{StaticResource StatusPill}"><TextBlock Style="{StaticResource PillText}" Text="{Binding ResultLabel}" /></Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Style="{StaticResource Empty}" Text="{loc:Loc Msg_NoData}" Visibility="{Binding HasTraining, Converter={StaticResource InverseBoolToVis}}" />
                    </StackPanel>
                </Border>

                <!-- Performance -->
                <Border Style="{StaticResource Section}">
                    <StackPanel>
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Style="{StaticResource Link}" Content="{loc:Loc Profile_OpenModule}" Command="{Binding GoPerformanceCommand}" />
                            <TextBlock Style="{StaticResource SectionTitle}" Text="{loc:Loc Perf_Title}" />
                        </DockPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0" Visibility="{Binding HasReview, Converter={StaticResource BoolToVis}}">
                            <Border Style="{StaticResource Tile}" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc Perf_Score}" />
                                    <TextBlock Style="{StaticResource TileValue}" Foreground="{DynamicResource Accent}">
                                        <Run Text="{Binding LatestScoreText, Mode=OneWay}" /><Run Text=" " /><Run Text="{Binding LatestRatingText, Mode=OneWay}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <TextBlock Style="{StaticResource Caption}" VerticalAlignment="Bottom" Text="{Binding LatestReviewPeriod}" />
                        </StackPanel>

                        <TextBlock Margin="0,14,0,4" Style="{StaticResource Caption}" Text="{loc:Loc Perf_Tab_Goals}" Visibility="{Binding HasGoals, Converter={StaticResource BoolToVis}}" />
                        <ItemsControl ItemsSource="{Binding Goals}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,6" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="140" /><ColumnDefinition Width="70" /><ColumnDefinition Width="100" /></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource RowText}" Text="{Binding Title}" />
                                            <ProgressBar Grid.Column="1" Height="8" VerticalAlignment="Center" Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=OneWay}"
                                                         Background="{DynamicResource SurfaceMuted}" Foreground="{DynamicResource Accent}" BorderThickness="0" />
                                            <TextBlock Grid.Column="2" Style="{StaticResource RowNum}" Text="{Binding ProgressText}" />
                                            <Border Grid.Column="3" Style="{StaticResource StatusPill}"><TextBlock Style="{StaticResource PillText}" Text="{Binding StatusLabel}" /></Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Margin="0,14,0,4" Style="{StaticResource Caption}" Text="{loc:Loc Perf_Tab_Career}" Visibility="{Binding HasCareer, Converter={StaticResource BoolToVis}}" />
                        <ItemsControl ItemsSource="{Binding Career}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="0,6" BorderBrush="{DynamicResource Border}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="100" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Style="{StaticResource RowMuted}" FontFamily="{StaticResource MonoFont}" Text="{Binding DateText}" />
                                            <TextBlock Grid.Column="1" Style="{StaticResource RowText}"><Run Text="{Binding Title, Mode=OneWay}" FontWeight="SemiBold" /><Run Text="  " /><Run Text="{Binding Detail, Mode=OneWay}" Foreground="{DynamicResource TextSecondary}" /></TextBlock>
                                            <TextBlock Grid.Column="2" Style="{StaticResource RowNum}" Text="{Binding ValueText}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Style="{StaticResource Empty}" Text="{loc:Loc Msg_NoData}"
                                   Visibility="{Binding HasPerformance, Converter={StaticResource InverseBoolToVis}}" />
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
