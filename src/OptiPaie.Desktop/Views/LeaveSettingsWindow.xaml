<Window x:Class="OptiPaie.Desktop.Views.LeaveSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Paramètres des congés" Height="300" Width="440"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" Background="{DynamicResource Canvas}">
    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource H2}" Text="{loc:Loc LeaveSet_Title}" />
            <TextBlock Style="{StaticResource Caption}" Margin="0,4,0,0" TextWrapping="Wrap"
                       Text="{loc:Loc LeaveSet_Hint}" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,18,0,0">
            <TextBlock Style="{StaticResource Caption}" Text="{loc:Loc LeaveSet_DaysPerMonth}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding DaysPerMonth, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Style="{StaticResource Caption}" Margin="0,12,0,0" Text="{loc:Loc LeaveSet_AnnualCap}" />
            <TextBox Style="{StaticResource AppTextBox}" Margin="0,4,0,0" Text="{Binding AnnualCap, UpdateSourceTrigger=PropertyChanged}" />

            <CheckBox Margin="0,16,0,0" IsChecked="{Binding ExcludeRestDays}"
                      Content="{loc:Loc LeaveSet_ExcludeRest}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Style="{StaticResource SecondaryButton}" Content="{loc:Loc Common_Cancel}" Command="{Binding CancelCommand}" />
            <Button Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Content="{loc:Loc Common_Save}" Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
