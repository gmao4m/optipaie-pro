<UserControl x:Class="OptiPaie.Desktop.Views.PremiumModuleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{DynamicResource Canvas}">
        <Grid Margin="28" MaxWidth="920" HorizontalAlignment="Left">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Hero -->
            <Border Grid.Row="0" Style="{StaticResource Card}" Padding="28">
                <DockPanel>
                    <!-- Large module icon with a lock badge -->
                    <Grid DockPanel.Dock="Left" Width="96" Height="96" VerticalAlignment="Top" Margin="0,0,24,0">
                        <Border CornerRadius="20" Background="{DynamicResource BrandSoft}" />
                        <Path Width="46" Height="46" Stretch="Uniform" Fill="{DynamicResource Brand}"
                              Data="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Border Width="34" Height="34" CornerRadius="17" Background="{DynamicResource TextPrimary}"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-6,-6"
                                BorderBrush="{DynamicResource Surface}" BorderThickness="3">
                            <Path Width="15" Height="15" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}"
                                  Data="{StaticResource IconLock}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>

                    <StackPanel VerticalAlignment="Center">
                        <Border Background="{DynamicResource BrandSoft}" CornerRadius="6" Padding="9,4"
                                HorizontalAlignment="Left" Margin="0,0,0,10">
                            <StackPanel Orientation="Horizontal">
                                <Path Width="12" Height="12" Stretch="Uniform" Fill="{DynamicResource Brand}"
                                      Data="{StaticResource IconLock}" VerticalAlignment="Center" />
                                <TextBlock Text="{loc:Loc Premium_Badge}" Margin="6,0,0,0" FontSize="10.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brand}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                        <TextBlock Style="{StaticResource H1}" Text="{Binding Title}" />
                        <TextBlock Style="{StaticResource Body}" Foreground="{DynamicResource TextSecondary}"
                                   Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="560" HorizontalAlignment="Left"
                                   Text="{Binding Description}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Features -->
            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="24" Margin="0,16,0,0">
                <StackPanel>
                    <TextBlock Style="{StaticResource H2}" Text="{loc:Loc Premium_KeyFeatures}" />
                    <ItemsControl Margin="0,14,0,0" ItemsSource="{Binding Features}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,7,16,7">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="24" Height="24" CornerRadius="12" Background="{DynamicResource BrandSoft}"
                                                VerticalAlignment="Center">
                                            <Path Width="13" Height="13" Stretch="Uniform" Fill="{DynamicResource Brand}"
                                                  Data="{StaticResource IconCheck}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <TextBlock Text="{Binding}" Margin="11,0,0,0" VerticalAlignment="Center"
                                                   TextWrapping="Wrap" Foreground="{DynamicResource TextPrimary}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Locked call-to-action -->
            <Border Grid.Row="2" Margin="0,16,0,0" CornerRadius="12" Background="{DynamicResource TextPrimary}" Padding="24">
                <DockPanel>
                    <Button DockPanel.Dock="Right" VerticalAlignment="Center" Style="{StaticResource PrimaryButton}"
                            Command="{Binding ContactSupportCommand}" Content="{loc:Loc Premium_ContactSupport}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="44" Height="44" CornerRadius="12" Background="#22FFFFFF" VerticalAlignment="Center">
                            <Path Width="22" Height="22" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}"
                                  Data="{StaticResource IconLock}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="14,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding LockTitle}" Foreground="{DynamicResource TextOnBrand}"
                                       FontSize="14.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding LockMessage}" Foreground="#C9D2DC" Margin="0,4,0,0"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
