<UserControl x:Class="OptiPaie.Desktop.Views.CompaniesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel HorizontalAlignment="Left">
                <TextBlock Style="{StaticResource H1}" Text="Entreprises" />
                <TextBlock Style="{StaticResource Caption}" Margin="0,5,0,0" Text="Gérez vos entreprises et leurs informations légales" />
            </StackPanel>
            <Button Style="{StaticResource PrimaryButton}" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding NewCommand}">
                <StackPanel Orientation="Horizontal">
                    <Path Width="15" Height="15" Stretch="Uniform" Fill="{DynamicResource TextOnBrand}" Data="{StaticResource IconPlus}" VerticalAlignment="Center" />
                    <TextBlock Text="Nouvelle entreprise" Margin="8,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0,22,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="12">
                        <TextBox Style="{StaticResource AppTextBox}" Text="{Binding Search, UpdateSourceTrigger=PropertyChanged}" Padding="34,0,10,0" />
                        <Path Width="16" Height="16" Stretch="Uniform" Fill="{DynamicResource TextMuted}" Data="{StaticResource IconSearch}"
                              HorizontalAlignment="Left" VerticalAlignment="Center" Margin="11,0,0,0" IsHitTestVisible="False" />
                        <TextBlock Text="Rechercher une entreprise" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center" Margin="34,0,0,0"
                                   IsHitTestVisible="False" Visibility="{Binding Search, Converter={StaticResource EmptyToVis}}" />
                    </Grid>

                    <ListBox Grid.Row="1" BorderThickness="0" Background="Transparent"
                             ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled" HorizontalContentAlignment="Stretch">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="6,1" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="b" Background="Transparent" CornerRadius="8" Padding="10,9">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource SurfaceMuted}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="b" Property="Background" Value="{DynamicResource BrandSoft}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="{Binding NameFr}" />
                                    <TextBlock Style="{StaticResource Caption}" Text="{Binding LegalForm}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="16,0,0,0">
                <Border Style="{StaticResource Card}" Visibility="{Binding HasSelection, Converter={StaticResource InverseBoolToVis}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="60" Height="60" CornerRadius="16" Background="{DynamicResource SurfaceMuted}" HorizontalAlignment="Center">
                            <Path Width="28" Height="28" Stretch="Uniform" Fill="{DynamicResource TextMuted}" Data="{StaticResource IconBuilding}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Style="{StaticResource Caption}" Margin="0,14,0,0" HorizontalAlignment="Center" Text="Sélectionnez une entreprise." />
                    </StackPanel>
                </Border>

                <DockPanel Visibility="{Binding HasSelection, Converter={StaticResource BoolToVis}}">
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Style="{StaticResource SecondaryButton}" Command="{Binding DeleteCommand}" Content="Supprimer" Foreground="{DynamicResource Deduction}" />
                        <Button Style="{StaticResource PrimaryButton}" Margin="12,0,0,0" Command="{Binding EditCommand}" Content="Modifier" />
                    </StackPanel>
                    <Border Style="{StaticResource Card}" Padding="24" VerticalAlignment="Top">
                        <StackPanel DataContext="{Binding SelectedCompany}">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="60" Height="60" CornerRadius="12" Background="{DynamicResource SurfaceMuted}" ClipToBounds="True">
                                    <Image Source="{Binding Logo, Converter={StaticResource BytesToImage}}" Stretch="Uniform" Margin="6" />
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource H2}" Text="{Binding NameFr}" />
                                    <TextBlock Style="{StaticResource Caption}" Text="{Binding LegalForm}" />
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{DynamicResource Border}" Margin="0,18" />

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,16,16">
                                    <TextBlock Style="{StaticResource Caption}" Text="NIF" />
                                    <TextBlock Margin="0,3,0,0" Text="{Binding Nif, TargetNullValue=—}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Style="{StaticResource Caption}" Text="RC" />
                                    <TextBlock Margin="0,3,0,0" Text="{Binding Rc, TargetNullValue=—}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,16">
                                    <TextBlock Style="{StaticResource Caption}" Text="N° CNAS employeur" />
                                    <TextBlock Margin="0,3,0,0" Text="{Binding CnasEmployerNumber, TargetNullValue=—}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,16">
                                    <TextBlock Style="{StaticResource Caption}" Text="Téléphone" />
                                    <TextBlock Margin="0,3,0,0" Text="{Binding Phone, TargetNullValue=—}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,16,0">
                                    <TextBlock Style="{StaticResource Caption}" Text="Adresse" />
                                    <TextBlock Margin="0,3,0,0" TextWrapping="Wrap" Text="{Binding AddressFr, TargetNullValue=—}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,0">
                                    <TextBlock Style="{StaticResource Caption}" Text="Banque" />
                                    <TextBlock Margin="0,3,0,0" Text="{Binding Bank, TargetNullValue=—}" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
