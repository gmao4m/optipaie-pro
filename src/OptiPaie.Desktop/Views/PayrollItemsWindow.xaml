<Window x:Class="OptiPaie.Desktop.Views.PayrollItemsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:OptiPaie.Desktop.Localization"
        Title="Rubriques de paie" Width="720" Height="540"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        FontFamily="{StaticResource AppFont}" Background="{DynamicResource Canvas}" Language="fr-FR"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource H2}" Text="{loc:Loc PayItem_Title}" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,12">
            <Button Style="{StaticResource PrimaryButton}" Height="34" Content="{loc:Loc Common_Add}" Command="{Binding NewCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Height="34" Margin="8,0,0,0" Content="{loc:Loc Common_Edit}" Command="{Binding EditCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Height="34" Margin="8,0,0,0" Content="{loc:Loc Common_Delete}" Foreground="{DynamicResource Deduction}" Command="{Binding DeleteCommand}" />
            <Button Style="{StaticResource SecondaryButton}" Height="34" Margin="8,0,0,0" Content="{loc:Loc Common_Close}" Command="{Binding CloseCommand}" />
        </StackPanel>

        <DataGrid Grid.Row="2" ItemsSource="{Binding Items}" SelectedItem="{Binding Selected}"
                  AutoGenerateColumns="False" HeadersVisibility="Column" IsReadOnly="True"
                  CanUserAddRows="False" CanUserResizeRows="False" GridLinesVisibility="Horizontal"
                  RowHeight="32" FontSize="12.5" Background="{DynamicResource Surface}"
                  RowBackground="{DynamicResource Surface}" AlternatingRowBackground="{DynamicResource SurfaceMuted}"
                  BorderBrush="{DynamicResource Border}" BorderThickness="1"
                  HorizontalGridLinesBrush="{DynamicResource Border}"
                  MouseDoubleClick="OnRowDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{loc:Loc Payroll_Col_Label}" Binding="{Binding NameFr}" Width="*" />
                <DataGridTextColumn Header="{loc:Loc Common_Nature}" Binding="{Binding ElementType, Converter={StaticResource ElementNature}}" Width="100" />
                <DataGridCheckBoxColumn Header="{loc:Loc PayItem_Contributable}" Binding="{Binding IsCnasApplicable}" Width="90" />
                <DataGridCheckBoxColumn Header="{loc:Loc PayItem_Taxable}" Binding="{Binding IsIrgApplicable}" Width="90" />
                <DataGridTextColumn Header="{loc:Loc PayItem_Order}" Binding="{Binding DisplayOrder}" Width="70" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
