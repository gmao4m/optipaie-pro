<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        DARK THEME palette. Same keys as Colors.xaml, dark values. Merged on top of the
        light palette at runtime by ThemeManager; because every colour is referenced via
        DynamicResource, the whole app re-themes live. The navy/teal identity is preserved
        on dark surfaces. Contrast is kept readable (light text on dark, white on filled).
    -->

    <!-- Brand: a mid-navy that stays visible on dark and reads with white button text. -->
    <SolidColorBrush x:Key="Brand" Color="#4A6BA8" />
    <SolidColorBrush x:Key="BrandHover" Color="#587AB9" />
    <SolidColorBrush x:Key="BrandPressed" Color="#3C5A92" />
    <SolidColorBrush x:Key="BrandSoft" Color="#28324A" />

    <!-- Accent: teal, brightened slightly for dark. -->
    <SolidColorBrush x:Key="Accent" Color="#17A99A" />
    <SolidColorBrush x:Key="AccentHover" Color="#149A8C" />
    <SolidColorBrush x:Key="AccentPressed" Color="#11857A" />
    <SolidColorBrush x:Key="AccentSoft" Color="#123A37" />

    <!-- Surfaces: near-black navy canvas, dark cards, subtle dividers. -->
    <SolidColorBrush x:Key="Canvas" Color="#12161F" />
    <SolidColorBrush x:Key="Surface" Color="#1A1F2B" />
    <SolidColorBrush x:Key="SurfaceMuted" Color="#232A38" />
    <SolidColorBrush x:Key="Border" Color="#2E3644" />
    <SolidColorBrush x:Key="BorderStrong" Color="#3B4453" />

    <!-- Text. -->
    <SolidColorBrush x:Key="TextPrimary" Color="#E8EAEE" />
    <SolidColorBrush x:Key="TextSecondary" Color="#B2B9C5" />
    <SolidColorBrush x:Key="TextMuted" Color="#7F8796" />
    <SolidColorBrush x:Key="TextOnBrand" Color="#FFFFFF" />

    <!-- Semantic status colours (lightened for dark backgrounds). -->
    <SolidColorBrush x:Key="Salary" Color="#43B57F" />
    <SolidColorBrush x:Key="Deduction" Color="#D97A7A" />
    <SolidColorBrush x:Key="Employer" Color="#6E90CC" />
    <SolidColorBrush x:Key="Warning" Color="#E2B65E" />

    <SolidColorBrush x:Key="StatusSuccess" Color="#43B57F" />
    <SolidColorBrush x:Key="StatusPending" Color="#E2B65E" />
    <SolidColorBrush x:Key="StatusDanger" Color="#D97A7A" />
    <SolidColorBrush x:Key="StatusNeutral" Color="#7F8796" />

    <!-- Destructive (filled) button: red with white text, tuned for dark. -->
    <SolidColorBrush x:Key="ButtonDanger" Color="#C0504E" />
    <SolidColorBrush x:Key="ButtonDangerHover" Color="#AD4644" />
    <SolidColorBrush x:Key="ButtonDangerPressed" Color="#933A38" />

    <!-- Disabled button: a dark neutral with a still-legible muted label. -->
    <SolidColorBrush x:Key="ButtonDisabledFill" Color="#2A313E" />
    <SolidColorBrush x:Key="ButtonDisabledText" Color="#99A0AC" />

</ResourceDictionary>
