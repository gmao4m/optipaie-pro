<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Design identity (light theme). A serious, bilingual B2B back-office palette:
        deep navy for primary presence, a distinctive deep-teal accent for the one or two
        most important actions, and warm off-white surfaces — deliberately not the generic
        cream/terracotta or neon-on-black look. Every screen draws from these tokens, so
        the identity is identical across the whole app.
    -->

    <!-- Brand: deep navy (primary actions, headers, brand presence) -->
    <Color x:Key="BrandColor">#1B2A4A</Color>
    <Color x:Key="BrandHoverColor">#243759</Color>
    <Color x:Key="BrandPressedColor">#142138</Color>
    <Color x:Key="BrandSoftColor">#E8ECF4</Color>

    <SolidColorBrush x:Key="Brand" Color="{StaticResource BrandColor}" />
    <SolidColorBrush x:Key="BrandHover" Color="{StaticResource BrandHoverColor}" />
    <SolidColorBrush x:Key="BrandPressed" Color="{StaticResource BrandPressedColor}" />
    <SolidColorBrush x:Key="BrandSoft" Color="{StaticResource BrandSoftColor}" />

    <!-- Accent: deep teal — the product's signature colour, used sparingly for the
         standout positive call-to-action per screen. -->
    <Color x:Key="AccentColor">#0F9B8E</Color>
    <Color x:Key="AccentHoverColor">#0C877B</Color>
    <Color x:Key="AccentPressedColor">#0A7267</Color>
    <Color x:Key="AccentSoftColor">#E0F3F1</Color>

    <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHover" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressed" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="AccentSoft" Color="{StaticResource AccentSoftColor}" />

    <!-- Surfaces: warm off-white canvas, white cards, soft warm dividers -->
    <SolidColorBrush x:Key="Canvas" Color="#F7F6F3" />
    <SolidColorBrush x:Key="Surface" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SurfaceMuted" Color="#F2F1EC" />
    <SolidColorBrush x:Key="Border" Color="#E4E1DA" />
    <SolidColorBrush x:Key="BorderStrong" Color="#D6D2C9" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#1B2430" />
    <SolidColorBrush x:Key="TextSecondary" Color="#4E5A69" />
    <SolidColorBrush x:Key="TextMuted" Color="#8B8F99" />
    <SolidColorBrush x:Key="TextOnBrand" Color="#FFFFFF" />

    <!-- Semantic status colours (used consistently everywhere; meaning is preserved:
         green = success/active/present/gain, amber = pending/late, red = danger/absent/
         deduction, blue = informational). -->
    <SolidColorBrush x:Key="Salary" Color="#2E9E6C" />
    <SolidColorBrush x:Key="Deduction" Color="#C24444" />
    <SolidColorBrush x:Key="Employer" Color="#2E4A78" />
    <SolidColorBrush x:Key="Warning" Color="#D9A441" />

    <!-- Status aliases (same semantics, clearer names for new screens) -->
    <SolidColorBrush x:Key="StatusSuccess" Color="#2E9E6C" />
    <SolidColorBrush x:Key="StatusPending" Color="#D9A441" />
    <SolidColorBrush x:Key="StatusDanger" Color="#C24444" />
    <SolidColorBrush x:Key="StatusNeutral" Color="#8B8F99" />

</ResourceDictionary>
