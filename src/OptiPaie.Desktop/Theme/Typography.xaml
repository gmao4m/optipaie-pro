<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!--
        UI font. IBM Plex is BUNDLED with the app (embedded as WPF resources in
        Assets/Fonts, see OptiPaie.Desktop.csproj), so these families resolve on every
        machine with no separate font installation and nothing falls back to a system
        font. "PlexUI" is a composite that renders Latin/French in IBM Plex Sans and
        Arabic in IBM Plex Sans Arabic, selected per-codepoint — so one family covers
        both languages with no Segoe fallback.
    -->
    <FontFamily x:Key="AppFont">/Assets/Fonts/#PlexUI</FontFamily>

    <!-- Separate handles when a single script is wanted explicitly. -->
    <FontFamily x:Key="AppFontLatin">/Assets/Fonts/#IBM Plex Sans</FontFamily>
    <FontFamily x:Key="AppFontArabic">/Assets/Fonts/#IBM Plex Sans Arabic</FontFamily>

    <!-- Monospace face (bundled IBM Plex Mono) for tabular numeric data — salaries, ids,
         amounts, dates, percentages, scores — so figures align in precise columns. -->
    <FontFamily x:Key="MonoFont">/Assets/Fonts/#IBM Plex Mono</FontFamily>

    <sys:Double x:Key="RadiusCard">12</sys:Double>
    <sys:Double x:Key="RadiusControl">8</sys:Double>

    <!-- 7-step type scale (single source of sizes) -->
    <sys:Double x:Key="FontSizeXxs">12</sys:Double>
    <sys:Double x:Key="FontSizeXs">14</sys:Double>
    <sys:Double x:Key="FontSizeSm">16</sys:Double>
    <sys:Double x:Key="FontSizeMd">18</sys:Double>
    <sys:Double x:Key="FontSizeLg">22</sys:Double>
    <sys:Double x:Key="FontSizeXl">28</sys:Double>
    <sys:Double x:Key="FontSizeXxl">36</sys:Double>

    <!-- Page title -->
    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

    <!-- Section heading -->
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="Body" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="22" />
        <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <Style x:Key="Caption" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
    </Style>

    <!-- Big figures (KPIs / net) — monospace so amounts stay column-aligned. -->
    <Style x:Key="Figure" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Tabular numeric figure (monospace) -->
    <Style x:Key="MonoFigure" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Default look for every TextBlock -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource AppFont}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
    </Style>

</ResourceDictionary>
